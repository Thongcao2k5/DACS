@model _18_3.Models.ShoppingCart

<h2>Giỏ hàng của bạn</h2>

@if (Model.Items.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Số lượng</th>
                <th>Giá</th>
                <th>Tổng</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Quantity</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@(item.Quantity * item.Price)</td>
                    <td>
                        <a asp-action="RemoveFromCart" asp-route-productId="@item.ProductId" class="btn btn-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3">Tổng cộng:</td>
                <td>@Model.ComputeTotalValue().ToString("C")</td>
                <td></td>
            </tr>
        </tfoot>
    </table>
    <a asp-action="Checkout" class="btn btn-success">Thanh toán</a>
}
else
{
    <p>Giỏ hàng trống.</p>
}
