@model IEnumerable<_18_3.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<div class="p-5 mb-4 bg-light rounded-3 text-center" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1558981285-6f0c94958bb6?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80'); background-size: cover; color: white;">
    <div class="container-fluid py-5">
        <h1 class="display-4 fw-bold">PHỤ TÙNG XE MÁY CHÍNH HÃNG</h1>
        <p class="col-md-8 fs-4 mx-auto">Chuyên cung cấp các loại lốp xe, dầu nhớt và phụ kiện cao cấp cho mọi dòng xe.</p>
        <a href="#products" class="btn btn-primary btn-lg">Mua sắm ngay</a>
    </div>
</div>

<div id="products" class="container mt-5">
    <h2 class="text-center mb-5 border-bottom pb-3">SẢN PHẨM NỔI BẬT</h2>
    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 250px; object-fit: cover;">
                        }
                        else
                        {
                            <img src="https://placehold.co/600x400?text=No+Image" class="card-img-top" style="height: 250px; object-fit: cover;">
                        }
                        <span class="position-absolute top-0 end-0 m-2 badge bg-danger">Mới</span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title text-primary">@product.Name</h5>
                        <p class="card-text text-muted small">@product.Category?.Name</p>
                        <p class="card-text">@product.Description</p>
                        <h4 class="text-danger fw-bold">@product.Price.ToString("N0") <span class="fs-6">VNĐ</span></h4>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 pb-3">
                        <div class="row g-2">
                            <div class="col-8">
                                <a asp-controller="Cart" asp-action="AddToCart" asp-route-productId="@product.Id" class="btn btn-primary w-100">
                                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ
                                </a>
                            </div>
                            <div class="col-4">
                                <a asp-area="" asp-controller="Product" asp-action="Display" asp-route-id="@product.Id" class="btn btn-outline-dark w-100">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
