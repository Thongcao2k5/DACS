@page
@model RegisterModel
@{
    ViewData["Title"] = "Gia nhập đội ngũ";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card border-0 shadow-lg overflow-hidden">
                <div class="row g-0">
                    <!-- Left Side - Decorative -->
                    <div class="col-md-4 d-none d-md-flex bg-dark align-items-center justify-content-center text-center p-4">
                        <div>
                            <i class="bi bi-person-plus text-primary display-1 mb-3"></i>
                            <h3 class="text-white fw-bold">WELCOME!</h3>
                            <p class="text-muted small px-3">Trở thành thành viên để nhận nhiều ưu đãi phụ tùng chính hãng.</p>
                        </div>
                    </div>
                    <!-- Right Side - Form -->
                    <div class="col-md-8">
                        <div class="card-body p-4 p-md-5">
                            <h2 class="fw-bold mb-4">ĐĂNG KÝ TÀI KHOẢN</h2>
                            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                                
                                <div class="row g-3 mb-3">
                                    <div class="col-md-12">
                                        <div class="form-floating">
                                            <input asp-for="Input.Email" class="form-control border-start-0 border-top-0 border-end-0 rounded-0 bg-transparent" placeholder="name@example.com" />
                                            <label asp-for="Input.Email"><i class="bi bi-envelope me-2"></i>Email của bạn</label>
                                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                        </div>
                                    </div>
                                    
                                    <div class="col-md-12">
                                        <div class="form-floating">
                                            <input asp-for="Input.FullName" class="form-control border-start-0 border-top-0 border-end-0 rounded-0 bg-transparent" placeholder="Họ và tên" />
                                            <label asp-for="Input.FullName"><i class="bi bi-person me-2"></i>Họ và tên</label>
                                            <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                                        </div>
                                    </div>

                                    <div class="col-md-8">
                                        <div class="form-floating">
                                            <input asp-for="Input.Address" class="form-control border-start-0 border-top-0 border-end-0 rounded-0 bg-transparent" placeholder="Địa chỉ" />
                                            <label asp-for="Input.Address"><i class="bi bi-geo-alt me-2"></i>Địa chỉ</label>
                                            <span asp-validation-for="Input.Address" class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-floating">
                                            <input asp-for="Input.Age" class="form-control border-start-0 border-top-0 border-end-0 rounded-0 bg-transparent" placeholder="Tuổi" />
                                            <label asp-for="Input.Age"><i class="bi bi-calendar-event me-2"></i>Tuổi</label>
                                            <span asp-validation-for="Input.Age" class="text-danger small"></span>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="form-floating">
                                            <input asp-for="Input.Password" class="form-control border-start-0 border-top-0 border-end-0 rounded-0 bg-transparent" placeholder="Mật khẩu" />
                                            <label asp-for="Input.Password"><i class="bi bi-lock me-2"></i>Mật khẩu</label>
                                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-floating">
                                            <input asp-for="Input.ConfirmPassword" class="form-control border-start-0 border-top-0 border-end-0 rounded-0 bg-transparent" placeholder="Xác nhận" />
                                            <label asp-for="Input.ConfirmPassword"><i class="bi bi-check2-circle me-2"></i>Xác nhận</label>
                                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-4 pt-2">
                                    <button id="registerSubmit" type="submit" class="btn btn-dark btn-lg w-100 py-3 shadow-sm border-0">
                                        ĐĂNG KÝ NGAY <i class="bi bi-arrow-right-short ms-2"></i>
                                    </button>
                                </div>

                                <div class="mt-4 text-center small">
                                    <span class="text-muted">Bạn đã là thành viên?</span>
                                    <a asp-page="./Login" class="text-primary fw-bold text-decoration-none ms-1">Đăng nhập tại đây</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
