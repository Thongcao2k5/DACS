@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-8">
            <div class="card border-0 shadow-lg overflow-hidden">
                <div class="bg-dark p-4 text-center">
                    <div class="mb-3">
                        <i class="bi bi-gear-wide-connected text-primary display-4"></i>
                    </div>
                    <h2 class="text-white fw-bold">MOTO SHOP</h2>
                    <p class="text-muted small text-uppercase tracking-wider">Đăng nhập để tiếp tục mua sắm</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope me-2"></i>Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="password" />
                            <label asp-for="Input.Password"><i class="bi bi-shield-lock me-2"></i>Mật khẩu</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label text-muted small" asp-for="Input.RememberMe">Ghi nhớ tôi</label>
                            </div>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="text-primary small text-decoration-none">Quên mật khẩu?</a>
                        </div>

                        <button id="login-submit" type="submit" class="btn btn-dark btn-lg w-100 mb-3 shadow-sm border-0 py-3">
                            ĐĂNG NHẬP NGAY
                        </button>

                        <div class="text-center">
                            <span class="text-muted small">Bạn chưa có tài khoản?</span>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary small fw-bold text-decoration-none ms-1">Đăng ký thành viên</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
