@model IEnumerable<MotoShop.Data.Models.Product>

@{
    ViewData["Title"] = "Danh sách Sản phẩm";
    Layout = "_AdminLayout";
}

@section Styles {
    <style>
        .product-img-admin { width: 50px; height: 50px; object-fit: cover; border-radius: 8px; border: 1px solid #eee; transition: 0.3s; }
        .product-img-admin:hover { transform: scale(1.1); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        .product-name-admin { font-weight: 600; color: #333; max-width: 280px; white-space: normal; line-height: 1.4; display: block; }
        .status-badge { font-size: 0.7rem; padding: 0.35em 0.8em; border-radius: 50rem; }
        .table > :not(caption) > * > * { padding: 1rem 0.5rem; vertical-align: middle; }
    </style>
}

<!-- Actions Bar -->
<div class="d-flex justify-content-between align-items-center mb-4 bg-white p-3 rounded-4 shadow-sm">
    <div>
        <h4 class="fw-bold mb-0">Quản lý Sản phẩm</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/Admin">Dashboard</a></li>
                <li class="breadcrumb-item active">Sản phẩm</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-danger rounded-pill px-4 fw-bold d-none btn-bulk-delete-action" onclick="handleBulkDelete()">
            <i class="bx bx-trash me-1"></i> XÓA ĐÃ CHỌN (<span class="selected-count-span">0</span>)
        </button>
        <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" data-bs-toggle="modal" data-bs-target="#addProductModal">
            <i class="bx bx-plus-circle me-1"></i> THÊM SẢN PHẨM MỚI
        </button>
    </div>
</div>

<!-- Modal Thêm Sản Phẩm -->
<div class="modal fade" id="addProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 600px;">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 p-4 pb-0">
                <h5 class="modal-title fw-bold text-uppercase fs-5">Thêm sản phẩm mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createProductForm" asp-area="Admin" asp-controller="Product" asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="IsActive" value="true">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Tên sản phẩm *</label>
                        <input type="text" name="ProductName" class="form-control custom-input" placeholder="Nhập tên sản phẩm" required>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Danh mục</label>
                            <select name="CategoryId" class="form-select custom-input" asp-items="ViewBag.CategoryList">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted">Thương hiệu</label>
                            <select name="BrandId" class="form-select custom-input" asp-items="ViewBag.BrandList">
                                <option value="">-- Chọn thương hiệu --</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Mô tả</label>
                        <textarea name="Description" class="form-control custom-input" rows="3" placeholder="Mô tả ngắn gọn..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted">Hình ảnh sản phẩm</label>
                        <input type="file" name="Images" class="form-control custom-input" multiple accept="image/*">
                        <div id="modalImagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
                    </div>

                    <!-- BẮT ĐẦU PHẦN BIẾN THỂ -->
                    <hr class="my-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <label class="form-label fw-bold text-primary mb-0"><i class="bx bx-list-ul me-1"></i> BIẾN THỂ SẢN PHẨM</label>
                        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill" onclick="addVariantRow()">
                            <i class="bx bx-plus me-1"></i> Thêm biến thể
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless align-middle" id="variantTable">
                            <thead>
                                <tr class="text-muted small">
                                    <th style="width: 40%">Tên biến thể *</th>
                                    <th>Giá bán</th>
                                    <th>SKU</th>
                                    <th>Kho</th>
                                    <th style="width: 40px"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Dòng mặc định -->
                                <tr class="variant-row">
                                    <td><input type="text" name="Variants[0].VariantName" class="form-control form-control-sm" placeholder="Mặc định" required></td>
                                    <td><input type="number" name="Variants[0].Price" class="form-control form-control-sm" placeholder="0" required></td>
                                    <td><input type="text" name="Variants[0].SKU" class="form-control form-control-sm" placeholder="SKU"></td>
                                    <td><input type="number" name="Variants[0].StockQuantity" class="form-control form-control-sm" value="0"></td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <!-- KẾT THÚC PHẦN BIẾN THỂ -->

                    <div class="form-check form-switch mt-3">
                        <input class="form-check-input" type="checkbox" name="IsFeatured" value="true">
                        <label class="form-check-label fw-bold">Sản phẩm nổi bật</label>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" id="btnSaveProduct" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                        LƯU SẢN PHẨM
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .custom-input { border-radius: 10px !important; border: 1px solid #ddd; padding: 10px 15px; transition: 0.3s; }
    .custom-input:focus { border-color: #696cff; box-shadow: 0 0 0 0.2rem rgba(105, 108, 255, 0.1); }
    .modal-content { animation: slideIn 0.3s ease-out; }
    @@keyframes slideIn {
        from { transform: translateY(-30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    .preview-thumb { width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 1px solid #eee; }
</style>

<!-- Filter Bar -->
<form id="filterForm" class="d-flex flex-wrap-nowrap gap-2 align-items-center" method="get">

    <div style="flex:2;">
        <div class="input-group">
            <span class="input-group-text"><i class="bx bx-search"></i></span>
            <input type="text" name="searchTerm" class="form-control"
                   placeholder="Tìm tên sản phẩm..."
                   value="@ViewContext.HttpContext.Request.Query["searchTerm"]">
        </div>
    </div>

    <div style="flex:1;">
        <select name="categoryId" class="form-select" asp-items="ViewBag.CategoryList">
            <option value="">Loại</option>
        </select>
    </div>

    <div style="flex:1;">
        <select name="brandId" class="form-select" asp-items="ViewBag.BrandList">
            <option value="">Thương hiệu</option>
        </select>
    </div>

    <div style="flex:1;">
        <select name="sort" class="form-select" asp-items="ViewBag.SortList">
            <option value="">Sắp xếp</option>
        </select>
    </div>

    <div style="flex:1; display:flex; gap:5px;">
        <button type="submit" class="btn btn-primary w-100">Lọc</button>
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Đặt lại</a>
        <button type="button" class="btn btn-danger d-none fw-bold" id="btnBulkDelete" onclick="handleBulkDelete()" style="white-space: nowrap; min-width: 100px;">
            XÓA (<span id="selectedCount">0</span>)
        </button>
    </div>

</form>
<!-- Table -->
<div class="card shadow-sm border-0 overflow-hidden">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover m-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 40px"><input class="form-check-input" type="checkbox" id="checkAll"></th>
                    <th style="width: 80px" class="col-img">Ảnh</th>
                    <th class="col-name">Tên sản phẩm</th>
                    <th class="col-brand">Thương hiệu</th>
                    <th class="col-category">Danh mục</th>
                    <th class="col-status">Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><input class="form-check-input row-checkbox" type="checkbox" value="@item.ProductId"></td>
                            <td class="col-img">
                                <img src="@(item.Images?.FirstOrDefault(i => i.IsPrimary)?.ImageUrl ?? "/assets/img/elements/no-image.png")" 
                                     class="product-img-admin" 
                                     onerror="this.src='/assets/img/elements/no-image.png'">
                            </td>
                            <td class="col-name">
                                <a asp-action="Edit" asp-route-id="@item.ProductId" class="product-name-admin">@item.ProductName</a>
                                <div class="d-flex gap-2 align-items-center">
                                    <small class="text-muted" style="font-size: 0.7rem;">SKU: @(item.Variants?.FirstOrDefault()?.SKU ?? "N/A")</small>
                                    @if (item.IsFeatured) { <span class="badge bg-label-warning status-badge"><i class="bx bxs-star"></i> Nổi bật</span> }
                                </div>
                            </td>
                            <td class="col-brand">@(item.Brand?.BrandName ?? "---")</td>
                            <td class="col-category">@(item.Category?.CategoryName ?? "---")</td>
                            <td class="col-status">
                                @if (item.IsActive) { <span class="badge bg-label-success status-badge">Đang bán</span> }
                                else { <span class="badge bg-label-secondary status-badge">Tạm ẩn</span> }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-icon btn-outline-primary" title="Chỉnh sửa"><i class="bx bx-edit-alt"></i></a>
                                    <button class="btn btn-sm btn-icon btn-outline-danger" onclick="confirmDelete(@item.ProductId, '@item.ProductName')" title="Xóa"><i class="bx bx-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5">
                            <div class="text-center">
                                <img src="/assets/img/illustrations/man-with-laptop-light.png" width="150" class="mb-3 opacity-50">
                                <h5 class="text-muted">Không tìm thấy sản phẩm nào khớp với bộ lọc</h5>
                                <button class="btn btn-primary" onclick="window.location.href='@Url.Action("Index")'">Xem tất cả</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <partial name="_AdminPagination" />
</div>

@section Scripts {
    <script>
        let variantIndex = 1;
        function addVariantRow() {
            const tbody = document.querySelector('#variantTable tbody');
            const newRow = document.createElement('tr');
            newRow.className = 'variant-row';
            newRow.innerHTML = `
                <td><input type="text" name="Variants[${variantIndex}].VariantName" class="form-control form-control-sm" placeholder="Tên biến thể" required></td>
                <td><input type="number" name="Variants[${variantIndex}].Price" class="form-control form-control-sm" placeholder="0" required></td>
                <td><input type="text" name="Variants[${variantIndex}].SKU" class="form-control form-control-sm" placeholder="SKU"></td>
                <td><input type="number" name="Variants[${variantIndex}].StockQuantity" class="form-control form-control-sm" value="0"></td>
                <td><button type="button" class="btn btn-sm text-danger p-0" onclick="removeVariantRow(this)"><i class="bx bx-trash"></i></button></td>
            `;
            tbody.appendChild(newRow);
            variantIndex++;
        }

        function removeVariantRow(btn) {
            btn.closest('tr').remove();
            reIndexVariants();
        }

        function reIndexVariants() {
            const rows = document.querySelectorAll('.variant-row');
            rows.forEach((row, index) => {
                row.querySelectorAll('input').forEach(input => {
                    const name = input.getAttribute('name');
                    if (name) {
                        input.setAttribute('name', name.replace(/\[\d+\]/, `[${index}]`));
                    }
                });
            });
            variantIndex = rows.length;
        }

        $(document).ready(function() {
            // 1. Logic chọn nhiều dòng và hiển thị nút Xóa hàng loạt
            function updateBulkDeleteButton() {
                const checkedCount = $('.row-checkbox:checked').length;
                const $btnBulk = $('.btn-bulk-delete-action, #btnBulkDelete');
                const $countSpan = $('.selected-count-span, #selectedCount');
                
                if (checkedCount >= 1) {
                    $btnBulk.removeClass('d-none');
                    $countSpan.text(checkedCount);
                } else {
                    $btnBulk.addClass('d-none');
                }
            }

            $('#checkAll').on('change', function() {
                $('.row-checkbox').prop('checked', $(this).prop('checked'));
                updateBulkDeleteButton();
            });

            $(document).on('change', '.row-checkbox', function() {
                updateBulkDeleteButton();
                // Tự động tắt checkAll nếu có 1 dòng không check
                if (!$(this).prop('checked')) {
                    $('#checkAll').prop('checked', false);
                }
            });

            // 2. Logic chọn cột hiển thị
            const columns = [
                { id: 'col-img', name: 'Ảnh' },
                { id: 'col-brand', name: 'Thương hiệu' },
                { id: 'col-category', name: 'Danh mục' },
                { id: 'col-status', name: 'Trạng thái' }
            ];

            const $menu = $('#columnToggleMenu');
            columns.forEach(col => {
                $menu.append(`
                    <div class="form-check mb-2">
                        <input class="form-check-input col-toggle" type="checkbox" value="${col.id}" id="toggle-${col.id}" checked>
                        <label class="form-check-label small" for="toggle-${col.id}">${col.name}</label>
                    </div>
                `);
            });

            $(document).on('change', '.col-toggle', function() {
                const colId = $(this).val();
                if ($(this).prop('checked')) {
                    $(`.${colId}`).show();
                } else {
                    $(`.${colId}`).hide();
                }
            });

            // 3. Hiệu ứng Loading Spinner khi submit form lọc
            $('#filterForm').on('submit', function() {
                if (typeof UI !== 'undefined' && UI.showLoader) UI.showLoader();
            });

            // 4. Auto-submit on select change (Chỉ áp dụng cho thanh lọc dữ liệu)
            $('#filterForm .form-select').on('change', function() {
                $('#filterForm').submit();
            });

            // 5. AJAX Form Submission for Modal
            $('#createProductForm').on('submit', function (e) {
                e.preventDefault(); 
                
                const form = $(this);
                const btn = $('#btnSaveProduct');
                const formData = new FormData(this);

                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Đang lưu...');
                if (typeof UI !== 'undefined' && UI.showLoader) UI.showLoader();

                $.ajax({
                    url: form.attr('action'),
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        if (typeof UI !== 'undefined' && UI.hideLoader) UI.hideLoader();
                        
                        if (response.success) {
                            $('#addProductModal').modal('hide');
                            UI.toast('Thêm sản phẩm thành công!', 'success');
                            setTimeout(() => location.reload(), 800);
                        } else {
                            let errorMsg = response.message || 'Lỗi lưu dữ liệu!';
                            UI.toast(errorMsg, 'error');
                            btn.prop('disabled', false).text('LƯU SẢN PHẨM');
                        }
                    },
                    error: function (xhr) {
                        if (typeof UI !== 'undefined' && UI.hideLoader) UI.hideLoader();
                        UI.toast('Lỗi hệ thống (500)', 'error');
                        btn.prop('disabled', false).text('LƯU SẢN PHẨM');
                    }
                });
            });

            // 6. Modal Image Preview
            $('input[name="Images"]').on('change', function (e) {
                const preview = $('#modalImagePreview');
                preview.empty();
                const files = e.target.files;
                for (let i = 0; i < files.length; i++) {
                    const reader = new FileReader();
                    reader.onload = function (event) {
                        preview.append(`<img src="${event.target.result}" class="preview-thumb">`);
                    };
                    reader.readAsDataURL(files[i]);
                }
            });
        });

        function confirmDelete(id, name) {
            UI.confirm({
                title: 'Xác nhận xóa',
                message: `Bạn có chắc chắn muốn xóa sản phẩm "<strong>${name}</strong>" không?`,
                type: 'danger',
                onConfirm: function() {
                    if (typeof UI !== 'undefined' && UI.showLoader) UI.showLoader();
                    
                    $.ajax({
                        url: '@Url.Action("Delete", "Product", new { area = "Admin" })',
                        type: 'POST',
                        data: { 
                            id: id,
                            __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function (response) {
                            if (typeof UI !== 'undefined' && UI.hideLoader) UI.hideLoader();
                            if (response.success) {
                                UI.toast(response.message || 'Đã xóa sản phẩm thành công', 'success');
                                setTimeout(() => location.reload(), 800);
                            } else {
                                UI.toast(response.message || 'Lỗi khi xóa sản phẩm', 'error');
                            }
                        },
                        error: function () {
                            if (typeof UI !== 'undefined' && UI.hideLoader) UI.hideLoader();
                            UI.toast('Lỗi hệ thống khi xóa sản phẩm', 'error');
                        }
                    });
                }
            });
        }

        function handleBulkDelete() {
            const selectedIds = $('.row-checkbox:checked').map(function() {
                return parseInt($(this).val());
            }).get();
            
            const count = selectedIds.length;
            
            UI.confirm({
                title: 'Xác nhận xóa nhiều',
                message: `Bạn có chắc muốn xóa vĩnh viễn <strong>${count}</strong> sản phẩm đã chọn?`,
                type: 'danger',
                onConfirm: function() {
                    if (typeof UI !== 'undefined' && UI.showLoader) UI.showLoader();
                    
                    $.ajax({
                        url: '@Url.Action("DeleteSelected", "Product", new { area = "Admin" })',
                        type: 'POST',
                        contentType: 'application/json',
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        },
                        data: JSON.stringify(selectedIds),
                        success: function (response) {
                            if (typeof UI !== 'undefined' && UI.hideLoader) UI.hideLoader();
                            if (response.success) {
                                UI.toast(response.message || `Đã xóa ${count} sản phẩm thành công`, 'success');
                                setTimeout(() => location.reload(), 800);
                            } else {
                                UI.toast(response.message || 'Lỗi khi xóa nhiều sản phẩm', 'error');
                            }
                        },
                        error: function () {
                            if (typeof UI !== 'undefined' && UI.hideLoader) UI.hideLoader();
                            UI.toast('Lỗi hệ thống khi xóa nhiều sản phẩm', 'error');
                        }
                    });
                }
            });
        }
    </script>
}