@model IEnumerable<MotoShop.Data.Models.Service>
@{
    ViewData["Title"] = "Danh sách Dịch vụ";
    Layout = "_AdminLayout";
}

@section Styles {
    <style>
      .service-name { font-weight: 700; color: #32475c; font-size: 0.95rem; }
      .service-desc { font-size: 0.8rem; color: #697a8d; white-space: normal; max-width: 400px; }
      .service-price { font-weight: 700; color: #E60023; }
    </style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0 text-uppercase">Dịch vụ kỹ thuật</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bx bx-plus me-1"></i>Thêm dịch vụ mới
    </a>
</div>

<div class="card overflow-hidden border-0 shadow-sm">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover m-0">
            <thead class="table-light">
                <tr>
                    <th>Tên dịch vụ & Mô tả</th>
                    <th>Giá dịch vụ</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="service-name">@item.ServiceName</div>
                            <div class="service-desc text-truncate">@item.Description</div>
                        </td>
                        <td><span class="service-price">@item.Price.ToString("N0")đ</span></td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.ServiceId" class="btn btn-sm btn-icon text-primary"><i class="bx bx-edit-alt"></i></a>
                            <button class="btn btn-sm btn-icon text-danger" onclick="confirmDelete(@item.ServiceId, '@item.ServiceName')"><i class="bx bx-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
