@model IEnumerable<MotoShop.Data.Models.Brand>
@{
    ViewData["Title"] = "Quản lý Thương hiệu";
    Layout = "_AdminLayout";
}

@section Styles {
    <style>
        .brand-logo-admin { width: 40px; height: 40px; object-fit: contain; border-radius: 4px; border: 1px solid #eee; padding: 2px; }
    </style>
}

<!-- Actions Bar -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0 text-uppercase">Thương hiệu</h4>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-primary" onclick="openCreateModal()">
            <i class="bx bx-plus me-1"></i> Thêm thương hiệu
        </button>
    </div>
</div>

<!-- Table -->
<div class="card overflow-hidden border-0 shadow-sm">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover m-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 40px"><input class="form-check-input" type="checkbox" id="checkAll"></th>
                    <th style="width: 80px">Logo</th>
                    <th>Tên thương hiệu</th>
                    <th>Mô tả</th>
                    <th class="text-center">Số SP</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><input class="form-check-input row-checkbox" type="checkbox" value="@item.BrandId"></td>
                        <td>
                            <img src="@(string.IsNullOrEmpty(item.LogoUrl) ? "/assets/img/elements/no-image.png" : item.LogoUrl)" 
                                 class="brand-logo-admin" 
                                 onerror="this.src='/assets/img/elements/no-image.png'">
                        </td>
                        <td><span class="fw-bold text-dark">@item.BrandName</span></td>
                        <td><small class="text-muted text-truncate d-block" style="max-width: 300px;">@item.Description</small></td>
                        <td class="text-center"><span class="badge bg-label-info">@item.Products.Count</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-icon text-primary" onclick="openEditModal(@item.BrandId, '@item.BrandName', '@item.LogoUrl', '@item.Description')"><i class="bx bx-edit-alt"></i></button>
                            <button class="btn btn-sm btn-icon text-danger" onclick="confirmDelete(@item.BrandId, '@item.BrandName')"><i class="bx bx-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Form -->
<div class="modal fade" id="brandModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg border-0 rounded-4">
            <div class="modal-header border-bottom p-4">
                <h5 class="modal-title fw-bold" id="modalTitle">Thêm thương hiệu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="brandForm">
                    <input type="hidden" id="brandId">
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase" for="brandName">Tên thương hiệu <span class="text-danger">*</span></label>
                        <input type="text" id="brandName" class="form-control rounded-3" placeholder="Ví dụ: Honda" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase" for="logoUrl">Logo URL</label>
                        <input type="text" id="logoUrl" class="form-control rounded-3" placeholder="https://...">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-uppercase" for="description">Mô tả</label>
                        <textarea id="description" class="form-control rounded-3" rows="3" placeholder="Mô tả về thương hiệu..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light-subtle p-4 border-top">
                <button type="button" class="btn btn-outline-secondary px-4 rounded-pill" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary px-4 rounded-pill" id="saveBrandBtn" onclick="handleSave()">Lưu dữ liệu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const brandModal = new bootstrap.Modal(document.getElementById('brandModal'));

        function openCreateModal() {
            $('#modalTitle').text('Thêm thương hiệu mới');
            $('#brandForm')[0].reset();
            $('#brandId').val('');
            brandModal.show();
        }

        function openEditModal(id, name, logo, desc) {
            $('#modalTitle').text('Cập nhật thương hiệu');
            $('#brandId').val(id);
            $('#brandName').val(name);
            $('#logoUrl').val(logo);
            $('#description').val(desc);
            brandModal.show();
        }

        function handleSave() {
            const data = {
                id: $('#brandId').val(),
                name: $('#brandName').val(),
                logoUrl: $('#logoUrl').val(),
                description: $('#description').val()
            };

            if (!data.name) { UI.toast('Vui lòng nhập tên thương hiệu', 'warning'); return; }

            showLoader();
            $.post('/Admin/Brand/Upsert', data, function(res) {
                hideLoader();
                if (res.success) {
                    brandModal.hide();
                    UI.toast('Lưu thành công!', 'success');
                    location.reload();
                } else {
                    UI.toast(res.message, 'error');
                }
            });
        }

        function confirmDelete(id, name) {
            UI.confirm({
                title: 'Xác nhận xóa',
                message: `Bạn có chắc chắn muốn xóa thương hiệu "<strong>${name}</strong>"?`,
                onConfirm: function() {
                    showLoader();
                    $.post('/Admin/Brand/Delete', { id: id }, function(res) {
                        hideLoader();
                        if (res.success) {
                            UI.toast('Đã xóa thành công', 'success');
                            location.reload();
                        } else {
                            UI.toast(res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
