@model IEnumerable<MotoShop.Data.Models.ProductReview>
@{
    ViewData["Title"] = "Quản lý Đánh giá";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold m-0 text-uppercase">Phản hồi khách hàng</h4>
</div>

<div class="card overflow-hidden border-0 shadow-sm">
    <div class="table-responsive text-nowrap">
        <table class="table table-hover m-0">
            <thead class="table-light">
                <tr>
                    <th>Khách hàng</th>
                    <th>Sản phẩm</th>
                    <th class="text-center">Đánh giá</th>
                    <th>Nội dung</th>
                    <th>Ngày gửi</th>
                    <th class="text-end">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="fw-bold">@item.Customer?.FullName</span></td>
                        <td><small>@item.Product?.ProductName</small></td>
                        <td class="text-center">
                            @for(int i=1; i<=5; i++) {
                                <i class='bx bxs-star @(i <= item.Rating ? "text-warning" : "text-light")'></i>
                            }
                        </td>
                        <td><small class="text-muted">@item.Comment</small></td>
                        <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">
                            @if (item.IsApproved)
                            {
                                <button class="btn btn-sm btn-outline-secondary" onclick="hideReview(@item.ReviewId)">Ẩn</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-primary" onclick="approveReview(@item.ReviewId)">Hiện</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function approveReview(id) {
            $.post('/Admin/Review/Approve', { id: id }, function() { location.reload(); });
        }
        function hideReview(id) {
            $.post('/Admin/Review/Hide', { id: id }, function() { location.reload(); });
        }
    </script>
}
