<!DOCTYPE html>
<html lang="vi" class="light-style layout-menu-fixed" dir="ltr" data-theme="theme-default" data-assets-path="/assets/">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - MotoShop Admin</title>
    
    <!-- Core CSS -->
    <link rel="stylesheet" href="/assets/vendor/css/core.css" />
    <link rel="stylesheet" href="/assets/vendor/css/theme-default.css" />
    <link rel="stylesheet" href="/assets/vendor/fonts/boxicons.css" />
    <link rel="stylesheet" href="/assets/css/demo.css" />
    
    <!-- Design System & UI Components -->
    <link rel="stylesheet" href="/assets/css/design-system.css" />
    <link rel="stylesheet" href="/assets/css/ui-interactions.css" />
    <link rel="stylesheet" href="/assets/css/pagination-component.css" />

    <style>
        /* FIX TRIỆT ĐỂ LỖI KHÔNG CLICK ĐƯỢC */
        #adminLoader { 
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
            background: rgba(255,255,255,0.7); 
            z-index: -1; /* Đẩy ra sau cùng khi không dùng */
            display: none; 
            align-items: center; justify-content: center; 
            pointer-events: none; /* Không nhận sự kiện chuột khi ẩn */
        }
        #adminLoader.active { 
            z-index: 9999; 
            display: flex !important; 
            pointer-events: all; /* Chỉ nhận sự kiện khi hiển thị */
        }

        /* Đảm bảo overlay của Sneat không chặn click trên Desktop */
        .layout-overlay { display: none !important; }
        @@media (max-width: 1199.98px) {
            .layout-overlay.layout-menu-toggle { display: block !important; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
  </head>
  <body>
    <!-- Global Loading Spinner -->
    <div id="adminLoader">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Đang xử lý...</span>
        </div>
    </div>

    <div class="layout-wrapper layout-content-navbar">
      <div class="layout-container">
        <!-- Sidebar -->
        <aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme shadow-sm">
            <div class="app-brand demo">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="app-brand-link">
                    <span class="app-brand-logo demo">
                         <i class='bx bxs-bolt-circle text-danger fs-3'></i>
                    </span>
                    <span class="app-brand-text demo menu-text fw-bolder ms-2">MOTOSHOP</span>
                </a>
            </div>
            <div class="menu-inner-shadow"></div>
            <ul class="menu-inner py-1 mt-3">
                <!-- Bảng điều khiển -->
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-home-circle"></i>
                        <div>Bảng điều khiển</div>
                    </a>
                </li>
                
                <!-- KHO HÀNG & SẢN PHẨM -->
                <li class="menu-header small text-uppercase"><span class="menu-header-text">Kho hàng & Sản phẩm</span></li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-box"></i>
                        <div>Sản phẩm</div>
                    </a>
                </li>
                <li class="menu-item @(new[] {"Category", "Brand", "MotorbikeModel", "Attribute", "Unit"}.Contains(ViewContext.RouteData.Values["controller"]?.ToString()) ? "active open" : "")">
                    <a href="javascript:void(0);" class="menu-link menu-toggle">
                        <i class="menu-icon tf-icons bx bx-wrench"></i>
                        <div>Cấu hình sản phẩm</div>
                    </a>
                    <ul class="menu-sub">
                        <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Category" asp-action="Index" class="menu-link"><div>Danh mục</div></a>
                        </li>
                        <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Brand" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Brand" asp-action="Index" class="menu-link"><div>Thương hiệu</div></a>
                        </li>
                        <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "MotorbikeModel" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="MotorbikeModel" asp-action="Index" class="menu-link"><div>Dòng xe</div></a>
                        </li>
                        <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Attribute" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Attribute" asp-action="Index" class="menu-link"><div>Thuộc tính</div></a>
                        </li>
                        <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Unit" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Unit" asp-action="Index" class="menu-link"><div>Đơn vị tính</div></a>
                        </li>
                    </ul>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Inventory" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Inventory" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-bar-chart-alt-2"></i>
                        <div>Quản lý tồn kho</div>
                    </a>
                </li>
                
                <!-- KINH DOANH -->
                <li class="menu-header small text-uppercase"><span class="menu-header-text">Kinh doanh</span></li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-cart"></i>
                        <div>Đơn hàng</div>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" || ViewContext.RouteData.Values["controller"]?.ToString() == "Service" ? "active open" : "")">
                    <a href="javascript:void(0);" class="menu-link menu-toggle">
                        <i class="menu-icon tf-icons bx bx-cog"></i>
                        <div>Dịch vụ kỹ thuật</div>
                    </a>
                    <ul class="menu-sub">
                        <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Service" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Service" asp-action="Index" class="menu-link"><div>Danh sách dịch vụ</div></a>
                        </li>
                        <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" ? "active" : "")">
                            <a asp-area="Admin" asp-controller="Booking" asp-action="Index" class="menu-link"><div>Lịch đặt dịch vụ</div></a>
                        </li>
                    </ul>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Promotion" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Promotion" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-gift"></i>
                        <div>Khuyến mãi</div>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Coupon" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Coupon" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-purchase-tag"></i>
                        <div>Mã giảm giá</div>
                    </a>
                </li>
                
                <!-- KHÁCH HÀNG & PHẢN HỒI -->
                <li class="menu-header small text-uppercase"><span class="menu-header-text">Khách hàng & Phản hồi</span></li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Customer" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Customer" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-group"></i>
                        <div>Danh sách khách hàng</div>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Review" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Review" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-star"></i>
                        <div>Đánh giá sản phẩm</div>
                    </a>
                </li>

                <!-- NỘI DUNG WEBSITE -->
                <li class="menu-header small text-uppercase"><span class="menu-header-text">Nội dung Website</span></li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Banner" || ViewContext.RouteData.Values["controller"]?.ToString() == "Slider" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-image"></i>
                        <div>Slider & Banner</div>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Blog" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-news"></i>
                        <div>Blog / Tin tức</div>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shipping" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Shipping" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-truck"></i>
                        <div>Phương thức vận chuyển</div>
                    </a>
                </li>

                <!-- HỆ THỐNG -->
                <li class="menu-header small text-uppercase"><span class="menu-header-text">Hệ thống</span></li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Account" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Account" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-user-circle"></i>
                        <div>Tài khoản & Nhân viên</div>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Store" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Store" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-store"></i>
                        <div>Cửa hàng / Chi nhánh</div>
                    </a>
                </li>
                <li class="menu-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Setting" ? "active" : "")">
                    <a asp-area="Admin" asp-controller="Setting" asp-action="Index" class="menu-link">
                        <i class="menu-icon tf-icons bx bx-cog"></i>
                        <div>Cài đặt hệ thống</div>
                    </a>
                </li>
            </ul>
        </aside>
        
        <div class="layout-page">
          <!-- Navbar -->
          <nav class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme" id="layout-navbar">
            <div class="layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
              <a class="nav-item nav-link px-0 me-xl-4" href="javascript:void(0)"><i class="bx bx-menu bx-sm"></i></a>
            </div>
            <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
              <h5 class="m-0 text-muted fw-light">Quản trị / <span class="text-dark fw-bold">@ViewData["Title"]</span></h5>
              
              <ul class="navbar-nav flex-row align-items-center ms-auto">
                <li class="nav-item navbar-dropdown dropdown-user dropdown">
                  <a class="nav-link dropdown-toggle hide-arrow" href="javascript:void(0);" data-bs-toggle="dropdown">
                    <div class="avatar avatar-online">
                        <img src="/assets/img/avatars/1.png" class="w-px-40 h-auto rounded-circle" />
                    </div>
                  </a>
                  <ul class="dropdown-menu dropdown-menu-end shadow border-0 p-2">
                    <li>
                      <div class="dropdown-item rounded">
                        <div class="d-flex align-items-center">
                          <div class="avatar avatar-online me-2"><img src="/assets/img/avatars/1.png" class="w-px-40 h-auto rounded-circle" /></div>
                          <div class="flex-grow-1">
                            <span class="fw-bold d-block small">@User.Identity?.Name</span>
                            <small class="text-muted" style="font-size: 10px;">Quản trị viên</small>
                          </div>
                        </div>
                      </div>
                    </li>
                    <li><div class="dropdown-divider"></div></li>
                    <li>
                        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="px-4 py-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="/Account/Login" />
                            <button type="submit" class="btn btn-danger btn-sm w-100">
                                <i class="bx bx-power-off me-2"></i> Đăng xuất
                            </button>
                        </form>
                    </li>
                  </ul>
                </li>
              </ul>
            </div>
          </nav>

          <div class="content-wrapper">
            <div class="container-xxl flex-grow-1 container-p-y">
                @RenderBody()
            </div>
            <footer class="content-footer footer bg-footer-theme text-center py-3 small text-muted">© 2026, MotoShop Admin</footer>
          </div>
        </div>
      </div>
    </div>

    <!-- Core JS (Phải nạp jQuery đầu tiên) -->
    <script src="/assets/vendor/libs/jquery/jquery.js"></script>
    <script src="/assets/vendor/js/bootstrap.js"></script>
    <script src="/assets/vendor/libs/perfect-scrollbar/perfect-scrollbar.js"></script>
    <script src="/assets/vendor/js/menu.js"></script>
    
    <!-- Sneat Main JS -->
    <script src="/assets/js/main.js"></script>
    
    <!-- Custom Design System JS -->
    <script src="/assets/js/design-system.js"></script>
    <script src="/assets/js/ui-interactions.js"></script>

    <script>
        function showLoader() { $('#adminLoader').addClass('active'); }
        function hideLoader() { $('#adminLoader').removeClass('active'); }
        
        $(document).ready(function() {
            // Đảm bảo không có overlay nào chặn click
            $('.layout-overlay').removeClass('show');
            
            // Tự động mở menu khi có submenu active
            $('.menu-item.active').parents('.menu-item').addClass('active open');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
  </body>
</html>
