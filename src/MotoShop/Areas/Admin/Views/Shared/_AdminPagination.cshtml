<div class="table-pagination-footer d-flex justify-content-between align-items-center p-3 border-top bg-light-subtle">
    <!-- Cột trái: Chọn số dòng -->
    <div class="pagination-rows-selector d-flex align-items-center">
        <span class="small text-muted">Hiển thị</span>
        <select class="form-select form-select-sm d-inline-block w-auto mx-2 rounded-pill shadow-sm" onchange="changePageSize(this.value)">
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
        <span class="small text-muted">dòng</span>
    </div>

    <!-- Cột giữa: Số trang -->
    <nav class="pagination-nav">
        <ul class="pagination pagination-sm m-0 gap-1">
            <li class="page-item disabled">
                <a class="page-link rounded-circle border-0 shadow-sm" href="#"><i class="bx bx-chevron-left"></i></a>
            </li>
            <li class="page-item active"><a class="page-link rounded-circle shadow-sm" href="#">1</a></li>
            <li class="page-item"><a class="page-link rounded-circle border-0 shadow-sm" href="#">2</a></li>
            <li class="page-item"><a class="page-link rounded-circle border-0 shadow-sm" href="#">3</a></li>
            <li class="page-item">
                <a class="page-link rounded-circle border-0 shadow-sm" href="#"><i class="bx bx-chevron-right"></i></a>
            </li>
        </ul>
    </nav>

    <!-- Cột phải: Tổng số dòng -->
    <div class="pagination-info text-muted small fw-bold">
        Hiển thị 1–10 / 124 dòng dữ liệu
    </div>
</div>
