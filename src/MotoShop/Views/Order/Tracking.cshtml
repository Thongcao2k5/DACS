@{
    ViewData["Title"] = "Theo dõi đơn hàng";
}

<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Theo dõi đơn hàng</li>
            </ol>
        </nav>
    </div>
</div>

<main class="container mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold">THEO DÕI ĐƠN HÀNG</h2>
        <p class="text-muted">Nhập mã đơn hàng và số điện thoại để kiểm tra trạng thái đơn hàng của bạn.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- 3. ORDER LOOKUP FORM -->
            <div class="tracking-lookup-box">
                <form class="row g-3 align-items-end" onsubmit="event.preventDefault(); showOrderDetails();">
                    <div class="col-md-5">
                        <label class="form-label-custom">Mã đơn hàng *</label>
                        <input type="text" class="form-control form-control-custom" placeholder="Ví dụ: MS-102345" required>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label-custom">Số điện thoại *</label>
                        <input type="tel" class="form-control form-control-custom" placeholder="Nhập số điện thoại đặt hàng" required>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-danger btn-lg w-100 rounded-pill fw-bold" style="height: 50px;">TRA CỨU</button>
                    </div>
                </form>
            </div>

            <!-- 4 & 5 & 6. ORDER DETAILS (Hidden by default, shown after lookup) -->
            <div id="orderDetailsSection" class="d-none animate__animated animate__fadeIn">
                <!-- Order Info Header -->
                <div class="order-info-card">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4 border-bottom pb-3">
                        <div>
                            <h5 class="fw-bold mb-1">Mã đơn hàng: #MS-102345</h5>
                            <p class="text-muted small mb-0">Ngày đặt: 12 Tháng 3, 2026 | Phương thức: COD</p>
                        </div>
                        <div class="status-indicator status-shipping">
                            <i class='bx bx-package'></i> ĐANG GIAO HÀNG
                        </div>
                    </div>

                    <!-- 5. STATUS TIMELINE -->
                    <div class="tracking-timeline-wrapper">
                        <div class="tracking-timeline">
                            <div class="timeline-progress" style="width: 50%;"></div> <!-- Width depends on status -->
                            
                            <div class="timeline-step completed">
                                <div class="step-icon-circle"><i class='bx bx-check'></i></div>
                                <div class="step-label">Đã đặt</div>
                                <div class="small text-muted mt-1" style="font-size: 10px;">12/03 - 08:30</div>
                            </div>
                            <div class="timeline-step completed">
                                <div class="step-icon-circle"><i class='bx bx-check'></i></div>
                                <div class="step-label">Xác nhận</div>
                                <div class="small text-muted mt-1" style="font-size: 10px;">12/03 - 10:15</div>
                            </div>
                            <div class="timeline-step active">
                                <div class="step-icon-circle"><i class='bx bx-truck'></i></div>
                                <div class="step-label">Đang giao</div>
                                <div class="small text-muted mt-1" style="font-size: 10px;">13/03 - 09:00</div>
                            </div>
                            <div class="timeline-step">
                                <div class="step-icon-circle"><i class='bx bx-map-pin'></i></div>
                                <div class="step-label">Chờ giao</div>
                            </div>
                            <div class="timeline-step">
                                <div class="step-icon-circle"><i class='bx bx-home-heart'></i></div>
                                <div class="step-label">Đã nhận</div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 pt-4 border-top">
                        <div class="col-md-6">
                            <span class="info-label">Địa chỉ nhận hàng</span>
                            <p class="info-value mb-0">Nguyễn Văn An - 0901 234 567<br>123 Đường ABC, Quận 1, TP. Hồ Chí Minh</p>
                        </div>
                        <div class="col-md-6">
                            <span class="info-label">Dự kiến giao hàng</span>
                            <p class="info-value mb-0 text-success">Thứ Hai, 16 Tháng 3, 2026</p>
                        </div>
                    </div>
                </div>

                <!-- 6. ORDER ITEMS -->
                <div class="order-info-card">
                    <h5 class="fw-bold mb-4 border-bottom pb-3">CHI TIẾT SẢN PHẨM</h5>
                    <ul class="summary-items-list">
                        <li class="summary-item-product">
                            <div class="summary-item-img">
                                <img src="https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=100" class="w-100 h-100 object-fit-contain p-1" alt="P">
                            </div>
                            <div class="summary-item-info flex-grow-1">
                                <span class="name">Bộ Nồi Trước Honda SH Chính Hãng</span>
                                <span class="qty-price">Số lượng: 1 x 1.250.000đ</span>
                            </div>
                            <div class="fw-bold">1.250.000đ</div>
                        </li>
                        <li class="summary-item-product">
                            <div class="summary-item-img">
                                <img src="https://images.unsplash.com/photo-1449426468159-d96dbf08f19f?w=100" class="w-100 h-100 object-fit-contain p-1" alt="P">
                            </div>
                            <div class="summary-item-info flex-grow-1">
                                <span class="name">Nhớt Motul 300V Factory Line 10W40</span>
                                <span class="qty-price">Số lượng: 2 x 450.000đ</span>
                            </div>
                            <div class="fw-bold">900.000đ</div>
                        </li>
                    </ul>
                    <div class="mt-4 pt-4 border-top text-end">
                        <div class="d-inline-block" style="min-width: 250px;">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tổng tiền sản phẩm:</span>
                                <span class="fw-bold">2.150.000đ</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Phí vận chuyển:</span>
                                <span class="fw-bold">30.000đ</span>
                            </div>
                            <div class="d-flex justify-content-between pt-2 border-top">
                                <span class="fw-bold fs-5">TỔNG THANH TOÁN:</span>
                                <span class="fw-bold fs-5 text-danger">2.180.000đ</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 7. CUSTOMER SUPPORT -->
            <div class="p-4 bg-light rounded-4 text-center">
                <h5 class="fw-bold mb-3">BẠN CẦN TRỢ GIÚP?</h5>
                <p class="text-muted mb-4">Nếu có bất kỳ thắc mắc nào về đơn hàng, vui lòng liên hệ với bộ phận chăm sóc khách hàng của chúng tôi.</p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="tel:0281234567" class="btn btn-outline-dark rounded-pill px-4 fw-bold">
                        <i class='bx bx-phone-call me-2'></i> 028 123 4567
                    </a>
                    <a href="mailto:support@motoshop.vn" class="btn btn-outline-dark rounded-pill px-4 fw-bold">
                        <i class='bx bx-envelope me-2'></i> support@motoshop.vn
                    </a>
                    <button class="btn btn-dark rounded-pill px-4 fw-bold">
                        <i class='bx bx-chat me-2'></i> CHAT TRỰC TUYẾN
                    </button>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function showOrderDetails() {
            // Giả lập tra cứu và hiện kết quả
            const section = document.getElementById('orderDetailsSection');
            section.classList.remove('d-none');
            // Cuộn xuống phần kết quả
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    </script>
}
