@{
    ViewData["Title"] = "Chính sách đổi trả";
}

<!-- 1. BREADCRUMB -->
<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Chính sách đổi trả</li>
            </ol>
        </nav>
    </div>
</div>

<main class="policy-page-wrapper">
    <div class="container">
        <div class="policy-content-box">
            <!-- 1. PAGE HEADER -->
            <header class="mb-5 text-center">
                <h1 class="fw-bold text-dark mb-3">CHÍNH SÁCH ĐỔI TRẢ SẢN PHẨM</h1>
                <p class="text-muted">MotoShop cam kết bảo vệ quyền lợi khách hàng thông qua chính sách đổi trả minh bạch.</p>
            </header>

            <!-- 2. INTRODUCTION -->
            <section class="policy-section">
                <h3 class="policy-section-title"><span>01</span> Giới thiệu chung</h3>
                <p class="policy-text">Nhằm đảm bảo quyền lợi tối đa cho khách hàng, MotoShop hỗ trợ đổi trả sản phẩm trong trường hợp sản phẩm phát sinh lỗi từ nhà sản xuất hoặc sản phẩm giao đến không đúng với đơn đặt hàng của quý khách.</p>
            </section>

            <!-- 3. RETURN CONDITIONS -->
            <section class="policy-section">
                <h3 class="policy-section-title"><span>02</span> Điều kiện đổi trả</h3>
                <p class="policy-text">Sản phẩm chỉ được chấp nhận đổi trả khi đáp ứng đầy đủ các tiêu chí sau:</p>
                <div class="return-condition-grid">
                    <div class="condition-card">
                        <i class='bx bx-box'></i>
                        <span>CÒN NGUYÊN VẸN BAO BÌ</span>
                    </div>
                    <div class="condition-card">
                        <i class='bx bx-no-entry'></i>
                        <span>CHƯA QUA SỬ DỤNG / LẮP ĐẶT</span>
                    </div>
                    <div class="condition-card">
                        <i class='bx bx-receipt'></i>
                        <span>CÓ HÓA ĐƠN MUA HÀNG</span>
                    </div>
                    <div class="condition-card">
                        <i class='bx bx-extension'></i>
                        <span>ĐẦY ĐỦ PHỤ KIỆN KÈM THEO</span>
                    </div>
                </div>
            </section>

            <!-- 4. RETURN TIME LIMIT -->
            <section class="policy-section">
                <h3 class="policy-section-title"><span>03</span> Thời hạn đổi trả</h3>
                <div class="alert alert-danger py-4 border-0 rounded-4 d-flex align-items-center gap-3">
                    <div class="fs-1"><i class='bx bx-calendar-exclamation'></i></div>
                    <div>
                        <h4 class="fw-bold mb-1">07 NGÀY</h4>
                        <p class="mb-0">Kể từ ngày quý khách nhận được hàng (theo biên bản giao hàng của shipper).</p>
                    </div>
                </div>
            </section>

            <!-- 5. RETURN PROCESS -->
            <section class="policy-section">
                <h3 class="policy-section-title"><span>04</span> Quy trình đổi trả</h3>
                <div class="delivery-step-wrapper">
                    <div class="service-process-list">
                        <div class="process-step">
                            <div class="process-step-number">1</div>
                            <h6 class="process-step-title">Liên hệ hỗ trợ</h6>
                            <p class="process-step-desc">Quý khách liên hệ qua Hotline 028 123 4567 hoặc gửi email kèm hình ảnh/video sản phẩm lỗi.</p>
                        </div>
                        <div class="process-step">
                            <div class="process-step-number">2</div>
                            <h6 class="process-step-title">Xác nhận tình trạng</h6>
                            <p class="process-step-desc">MotoShop tiến hành kiểm tra thông tin và xác nhận điều kiện đổi trả trực tuyến.</p>
                        </div>
                        <div class="process-step">
                            <div class="process-step-number">3</div>
                            <h6 class="process-step-title">Gửi hàng về cửa hàng</h6>
                            <p class="process-step-desc">Quý khách đóng gói và gửi sản phẩm về địa chỉ chi nhánh gần nhất của MotoShop.</p>
                        </div>
                        <div class="process-step">
                            <div class="process-step-number">4</div>
                            <h6 class="process-step-title">Xử lý đổi trả</h6>
                            <p class="process-step-desc">Sau khi nhận được hàng, chúng tôi sẽ kiểm tra thực tế và tiến hành đổi mới hoặc hoàn tiền trong 24h.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- 6. REFUND METHOD -->
            <section class="policy-section mb-0">
                <h3 class="policy-section-title"><span>05</span> Phương thức hoàn tiền</h3>
                <p class="policy-text">Tùy theo nhu cầu, khách hàng có thể lựa chọn một trong các hình thức hoàn trả sau:</p>
                <div class="refund-method-list">
                    <div class="refund-item">
                        <i class='bx bx-transfer'></i>
                        <span>CHUYỂN KHOẢN NGÂN HÀNG</span>
                    </div>
                    <div class="refund-item">
                        <i class='bx bx-wallet'></i>
                        <span>VÍ ĐIỆN TỬ (MOMO/ZALOPAY)</span>
                    </div>
                    <div class="refund-item">
                        <i class='bx bx-repost'></i>
                        <span>ĐỔI SANG SẢN PHẨM KHÁC</span>
                    </div>
                </div>
            </section>
        </div>
    </div>
</main>
