@{
    ViewData["Title"] = "Giới thiệu về MotoShop";
}

<!-- 1. BREADCRUMB -->
<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Giới thiệu</li>
            </ol>
        </nav>
    </div>
</div>

<!-- 1. PAGE HERO -->
<section class="about-hero mb-5">
    <div class="container">
        <h1 class="display-3 fw-bolder mb-3">GIỚI THIỆU MOTOSHOP</h1>
        <p class="fs-5 opacity-75 max-width-700 mx-auto">Hệ thống phân phối phụ tùng xe máy chính hãng và dịch vụ bảo dưỡng tiêu chuẩn quốc tế.</p>
    </div>
</section>

<main>
    <!-- 2. ABOUT INTRODUCTION -->
    <section class="container mb-5">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <img src="https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=800" class="about-intro-img img-fluid" alt="MotoShop Store">
            </div>
            <div class="col-lg-6">
                <h2 class="fw-bold mb-4">CHÚNG TÔI LÀ AI?</h2>
                <p class="fs-5 text-dark mb-4">MotoShop được thành lập với mục tiêu mang đến các sản phẩm phụ tùng xe máy chất lượng cao cùng dịch vụ sửa chữa chuyên nghiệp bậc nhất.</p>
                <p class="text-muted mb-4">Trải qua hơn 5 năm hình thành và phát triển, chúng tôi tự hào là đối tác chiến lược của nhiều thương hiệu phụ tùng hàng đầu thế giới. Với phương châm "Xế yêu của bạn là ưu tiên của chúng tôi", MotoShop không ngừng cải tiến quy trình kỹ thuật để mang lại sự an tâm tuyệt đối.</p>
                
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center gap-2 fw-bold text-dark">
                            <i class='bx bx-check-double text-danger fs-4'></i> Sản phẩm chính hãng 100%
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center gap-2 fw-bold text-dark">
                            <i class='bx bx-check-double text-danger fs-4'></i> Giá cả minh bạch, rõ ràng
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center gap-2 fw-bold text-dark">
                            <i class='bx bx-check-double text-danger fs-4'></i> Dịch vụ tận tâm, chu đáo
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="d-flex align-items-center gap-2 fw-bold text-dark">
                            <i class='bx bx-check-double text-danger fs-4'></i> Bảo hành dài hạn lên tới 2 năm
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 3. SHOP STORY (Timeline) -->
    <section class="bg-light py-5 mb-5">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="fw-bold">HÀNH TRÌNH PHÁT TRIỂN</h2>
                <p class="text-muted">Nhìn lại những cột mốc quan trọng làm nên thương hiệu MotoShop</p>
            </div>
            
            <div class="story-timeline">
                <!-- 2018 -->
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <span class="timeline-year">2018</span>
                    <h5 class="fw-bold">Khởi đầu đam mê</h5>
                    <p class="small text-muted">Thành lập cửa hàng nhỏ đầu tiên tại TP.HCM chuyên về sửa chữa và phục hồi xe tay ga đời cũ.</p>
                </div>
                <!-- 2020 -->
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <span class="timeline-year">2020</span>
                    <h5 class="fw-bold">Mở rộng quy mô</h5>
                    <p class="small text-muted">Trở thành trung tâm bảo dưỡng chuyên nghiệp với hệ thống máy móc hiện đại như máy vệ sinh kim phun Fi, buồng đốt.</p>
                </div>
                <!-- 2022 -->
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <span class="timeline-year">2022</span>
                    <h5 class="fw-bold">Chinh phục môi trường số</h5>
                    <p class="small text-muted">Ra mắt hệ thống bán lẻ phụ tùng online, giao hàng nhanh chóng đến mọi tỉnh thành trên toàn quốc.</p>
                </div>
                <!-- 2025 -->
                <div class="timeline-item">
                    <div class="timeline-dot"></div>
                    <span class="timeline-year">2025</span>
                    <h5 class="fw-bold">Hệ sinh thái MotoShop</h5>
                    <p class="small text-muted">Phát triển ứng dụng di động và hệ thống thương mại điện tử tích hợp dịch vụ đặt lịch hẹn thông minh.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 4. WHY CHOOSE US & 5. STATISTICS -->
    <section class="container mb-5 pb-5">
        <div class="row g-4 mb-5">
            <div class="col-md-6 col-lg-3">
                <div class="advantage-box h-100 flex-column text-center px-4">
                    <div class="advantage-icon mb-3 me-0"><i class='bx bx-award'></i></div>
                    <h6>SẢN PHẨM CHÍNH HÃNG</h6>
                    <p>Chúng tôi chỉ phân phối phụ tùng từ các thương hiệu uy tín: Honda, Yamaha, Motul, Ohlins...</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="advantage-box h-100 flex-column text-center px-4">
                    <div class="advantage-icon mb-3 me-0"><i class='bx bx-wrench'></i></div>
                    <h6>KỸ THUẬT VIÊN GIỎI</h6>
                    <p>Đội ngũ kỹ thuật viên tay nghề cao, được đào tạo bài bản và am hiểu mọi dòng xe.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="advantage-box h-100 flex-column text-center px-4">
                    <div class="advantage-icon mb-3 me-0"><i class='bx bx-dollar-circle'></i></div>
                    <h6>GIÁ CẢ MINH BẠCH</h6>
                    <p>Mọi phụ tùng và dịch vụ đều được niêm yết giá rõ ràng, tuyệt đối không phát sinh chi phí.</p>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="advantage-box h-100 flex-column text-center px-4">
                    <div class="advantage-icon mb-3 me-0"><i class='bx bx-support'></i></div>
                    <h6>HỖ TRỢ NHANH CHÓNG</h6>
                    <p>Luôn sẵn sàng tư vấn kỹ thuật 24/7 thông qua hotline và các kênh chat trực tuyến.</p>
                </div>
            </div>
        </div>

        <!-- Statistics Counters -->
        <div class="row g-4 pt-5 border-top">
            <div class="col-6 col-lg-3">
                <div class="stat-counter-item">
                    <span class="stat-number">5000+</span>
                    <span class="stat-text">Khách hàng tin dùng</span>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-counter-item">
                    <span class="stat-number">2000+</span>
                    <span class="stat-text">Đơn hàng mỗi tháng</span>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-counter-item">
                    <span class="stat-number">50+</span>
                    <span class="stat-text">Thương hiệu đối tác</span>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="stat-counter-item">
                    <span class="stat-number">05+</span>
                    <span class="stat-text">Năm kinh nghiệm</span>
                </div>
            </div>
        </div>
    </section>

    <!-- 6. TEAM SECTION -->
    <section class="bg-light py-5 mb-5">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="fw-bold">ĐỘI NGŨ CHUYÊN GIA</h2>
                <p class="text-muted">Gặp gỡ những người thợ lành nghề tạo nên chất lượng dịch vụ của chúng tôi</p>
            </div>
            <div class="row g-4 justify-content-center">
                <div class="col-md-4 col-lg-3">
                    <div class="team-card">
                        <img src="https://i.pravatar.cc/150?u=tech1" class="team-avatar" alt="Team">
                        <h5 class="team-name">Nguyễn Văn An</h5>
                        <span class="team-role">Kỹ thuật viên trưởng</span>
                    </div>
                </div>
                <div class="col-md-4 col-lg-3">
                    <div class="team-card">
                        <img src="https://i.pravatar.cc/150?u=tech2" class="team-avatar" alt="Team">
                        <h5 class="team-name">Trần Minh Thắng</h5>
                        <span class="team-role">Chuyên gia bảo dưỡng</span>
                    </div>
                </div>
                <div class="col-md-4 col-lg-3">
                    <div class="team-card">
                        <img src="https://i.pravatar.cc/150?u=tech3" class="team-avatar" alt="Team">
                        <h5 class="team-name">Lê Quang Hải</h5>
                        <span class="team-role">Kỹ sư điện Fi</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 7. CUSTOMER TRUST (Testimonials) -->
    <section class="container mb-5 py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold">KHÁCH HÀNG NÓI GÌ?</h2>
            <p class="text-muted">Sự hài lòng của khách hàng là thước đo thành công lớn nhất của MotoShop</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-lg-5">
                <div class="testimonial-card">
                    <p class="testimonial-text">"Phụ tùng chính hãng, giá tốt và kỹ thuật làm rất cẩn thận. Mình đã làm nồi xe SH ở đây và rất hài lòng với độ êm ái sau dịch vụ."</p>
                    <span class="testimonial-author">Anh Hoàng (Quận 1, TP.HCM)</span>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="testimonial-card">
                    <p class="testimonial-text">"Nhân viên tư vấn rất nhiệt tình, giải thích cặn kẽ từng loại phụ tùng. Giao hàng về tỉnh cũng rất nhanh và đóng gói kỹ."</p>
                    <span class="testimonial-author">Chị Lan (Biên Hòa, Đồng Nai)</span>
                </div>
            </div>
        </div>
    </section>

    <!-- 8. CTA SECTION -->
    <section class="container mb-5">
        <div class="support-info-box" style="border-radius: 40px;">
            <h2 class="fw-bold mb-4">SẴN SÀNG CHĂM SÓC XẾ YÊU CỦA BẠN?</h2>
            <p class="mb-5 opacity-75">Hãy khám phá các sản phẩm phụ tùng tốt nhất hoặc đặt lịch bảo dưỡng ngay hôm nay.</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Product" asp-action="Index" class="btn btn-white text-danger bg-white btn-lg rounded-pill px-5 fw-bold">XEM SẢN PHẨM</a>
                <a asp-controller="Service" asp-action="Index" class="btn btn-outline-light btn-lg rounded-pill px-5 fw-bold">ĐẶT LỊCH HẸN</a>
                <a asp-controller="Info" asp-action="Contact" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold">LIÊN HỆ NGAY</a>
            </div>
        </div>
    </section>
</main>
