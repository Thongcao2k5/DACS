@model List<MotoShop.Business.DTOs.CartItemDto>
@{
    ViewData["Title"] = "Giỏ hàng";
    var totalAmount = Model.Sum(i => i.Total);
}

<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Giỏ hàng của bạn</li>
            </ol>
        </nav>
    </div>
</div>

<main class="container mb-5">
    @if (Model.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">Giỏ hàng <span class="fs-5 text-muted fw-normal">(@Model.Count sản phẩm)</span></h2>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="cart-table-wrapper bg-white rounded-4 shadow-sm overflow-hidden">
                    <table class="cart-table w-100">
                        <thead class="bg-light">
                            <tr>
                                <th class="p-3">Sản phẩm</th>
                                <th class="p-3 text-center">Giá</th>
                                <th class="p-3 text-center" style="width: 150px;">Số lượng</th>
                                <th class="p-3 text-center">Tổng cộng</th>
                                <th class="p-3"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="cart-item-row border-bottom" data-variant-id="@item.ProductVariantId" data-price="@item.Price">
                                    <td class="p-3">
                                        <div class="cart-product d-flex align-items-center gap-3">
                                            <div class="cart-product-img" style="width: 80px; height: 80px;">
                                                <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/assets/img/elements/no-image.png" : item.ImageUrl)" class="w-100 h-100 object-fit-cover rounded" alt="@item.ProductName">
                                            </div>
                                            <div class="cart-product-info">
                                                <a href="/Product/Details/@item.ProductVariantId" class="name fw-bold text-dark text-decoration-none d-block">@item.ProductName</a>
                                                <span class="variant text-muted small">@item.VariantName</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="p-3 text-center"><div class="cart-price fw-semibold">@item.Price.ToString("N0")đ</div></td>
                                    <td class="p-3 text-center">
                                        <div class="qty-selector d-flex align-items-center justify-content-center">
                                            <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="updateCartQty(this, -1)"><i class='bx bx-minus'></i></button>
                                            <input type="text" class="qty-input form-control form-control-sm text-center border-0 fw-bold" style="width: 40px;" value="@item.Quantity" readonly>
                                            <button class="btn btn-sm btn-outline-secondary rounded-circle" onclick="updateCartQty(this, 1)"><i class='bx bx-plus'></i></button>
                                        </div>
                                    </td>
                                    <td class="p-3 text-center"><div class="cart-subtotal fw-bold text-danger">@item.Total.ToString("N0")đ</div></td>
                                    <td class="p-3 text-center"><button class="btn btn-link text-muted p-0" onclick="removeCartItem(this)"><i class='bx bx-trash fs-5'></i></button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="cart-summary-card bg-white rounded-4 shadow-sm p-4 sticky-top" style="top: 20px;">
                    <h5 class="fw-bold mb-4 text-uppercase">TỔNG ĐƠN HÀNG</h5>
                    <div class="summary-item d-flex justify-content-between mb-3 pb-3 border-bottom">
                        <span class="text-muted">Tạm tính</span>
                        <span class="fw-bold" id="totalSubtotal">@totalAmount.ToString("N0")đ</span>
                    </div>
                    <div class="summary-item d-flex justify-content-between mb-3">
                        <span class="text-muted">Phí vận chuyển</span>
                        <span class="text-muted small">Tính lúc thanh toán</span>
                    </div>
                    <div class="summary-total d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold fs-5">TỔNG CỘNG</span>
                        <span class="price fs-3 fw-bolder text-danger" id="totalFinal">@totalAmount.ToString("N0")đ</span>
                    </div>
                    <a href="/Cart/Checkout" class="btn btn-danger btn-lg w-100 rounded-pill fw-bold mb-3 py-3 shadow-sm">TIẾN HÀNH THANH TOÁN</a>
                    <a href="/Product" class="btn btn-outline-secondary btn-lg w-100 rounded-pill fw-bold py-3">TIẾP TỤC MUA HÀNG</a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="container text-center py-5">
            <div class="empty-cart-icon mb-4"><i class='bx bx-shopping-bag display-1 text-muted opacity-25'></i></div>
            <h3 class="fw-bold">Giỏ hàng của bạn đang trống</h3>
            <p class="text-muted mb-4">Có vẻ như bạn chưa thêm sản phẩm nào vào giỏ hàng.</p>
            <a href="/Product" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold shadow-sm">QUAY LẠI CỬA HÀNG</a>
        </div>
    }
</main>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        async function updateCartQty(btn, val) {
            const row = btn.closest('.cart-item-row');
            const variantId = row.getAttribute('data-variant-id');
            const input = row.querySelector('.qty-input');
            const price = parseInt(row.getAttribute('data-price'));
            const subtotalEl = row.querySelector('.cart-subtotal');
            
            let newQty = parseInt(input.value) + val;
            if (newQty < 1) return;

            try {
                const response = await fetch('/Cart/UpdateQuantity', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `variantId=${variantId}&quantity=${newQty}`
                });
                const data = await response.json();
                if (data.success) {
                    input.value = newQty;
                    const subtotal = price * newQty;
                    subtotalEl.innerText = subtotal.toLocaleString('vi-VN') + 'đ';
                    updateTotalCart();
                } else {
                    Swal.fire('Lỗi', 'Không thể cập nhật số lượng. Có thể do hết hàng.', 'error');
                }
            } catch (error) {
                console.error(error);
            }
        }

        async function removeCartItem(btn) {
            const result = await Swal.fire({
                title: 'Xóa sản phẩm?',
                text: "Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Có, xóa ngay!',
                cancelButtonText: 'Hủy'
            });

            if (result.isConfirmed) {
                const row = btn.closest('.cart-item-row');
                const variantId = row.getAttribute('data-variant-id');

                try {
                    const response = await fetch('/Cart/RemoveFromCart', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: `variantId=${variantId}`
                    });
                    const data = await response.json();
                    if (data.success) {
                        row.remove();
                        updateTotalCart();
                        if (document.querySelectorAll('.cart-item-row').length === 0) {
                            window.location.reload();
                        }
                    }
                } catch (error) {
                    console.error(error);
                }
            }
        }

        function updateTotalCart() {
            let total = 0;
            document.querySelectorAll('.cart-item-row').forEach(row => {
                const price = parseInt(row.getAttribute('data-price'));
                const qty = parseInt(row.querySelector('.qty-input').value);
                total += price * qty;
            });
            
            const formatted = total.toLocaleString('vi-VN') + 'đ';
            document.getElementById('totalSubtotal').innerText = formatted;
            document.getElementById('totalFinal').innerText = formatted;
            if (typeof updateCartBadge === "function") updateCartBadge();
        }
    </script>
}
