@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<main class="container">
    <div class="success-container">
        <!-- 1. SUCCESS MESSAGE -->
        <div class="success-icon-wrapper">
            <i class='bx bx-check'></i>
        </div>
        <h1 class="fw-bold text-dark mb-2">ĐẶT HÀNG THÀNH CÔNG!</h1>
        <p class="text-muted mb-5">Cảm ơn bạn đã mua sắm tại <span class="text-danger fw-bold">MotoShop</span>. Đơn hàng của bạn đã được ghi nhận và đang được xử lý.</p>

        <div class="row g-4 text-start">
            <div class="col-lg-7">
                <!-- 2. ORDER INFORMATION -->
                <div class="order-info-card">
                    <h5 class="fw-bold mb-4 border-bottom pb-3">THÔNG TIN ĐƠN HÀNG</h5>
                    <div class="info-grid">
                        <div>
                            <span class="info-label">Mã đơn hàng</span>
                            <span class="info-value">#MS-102345</span>
                        </div>
                        <div>
                            <span class="info-label">Ngày đặt hàng</span>
                            <span class="info-value">12 Tháng 3, 2026</span>
                        </div>
                        <div>
                            <span class="info-label">Phương thức thanh toán</span>
                            <span class="info-value">Thanh toán khi nhận hàng (COD)</span>
                        </div>
                        <div>
                            <span class="info-label">Trạng thái</span>
                            <span class="badge bg-warning text-dark fw-bold">Đang xử lý</span>
                        </div>
                    </div>
                    <div class="mt-4 pt-4 border-top">
                        <span class="info-label">Địa chỉ giao hàng</span>
                        <span class="info-value">Nguyễn Văn An - 0901 234 567<br>123 Đường ABC, Phường 5, Quận 1, TP. Hồ Chí Minh</span>
                    </div>
                </div>

                <!-- 3. ORDER SUMMARY (Simplified) -->
                <div class="order-info-card">
                    <h5 class="fw-bold mb-4 border-bottom pb-3">SẢN PHẨM ĐÃ ĐẶT (2)</h5>
                    <ul class="summary-items-list mb-0">
                        <li class="summary-item-product">
                            <div class="summary-item-img">
                                <img src="https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=100" class="w-100 h-100 object-fit-contain p-1" alt="P">
                            </div>
                            <div class="summary-item-info flex-grow-1">
                                <span class="name">Bộ Nồi Trước Honda SH Chính Hãng</span>
                                <span class="qty-price">Số lượng: 1 x 1.250.000đ</span>
                            </div>
                            <div class="fw-bold">1.250.000đ</div>
                        </li>
                        <li class="summary-item-product">
                            <div class="summary-item-img">
                                <img src="https://images.unsplash.com/photo-1449426468159-d96dbf08f19f?w=100" class="w-100 h-100 object-fit-contain p-1" alt="P">
                            </div>
                            <div class="summary-item-info flex-grow-1">
                                <span class="name">Nhớt Motul 300V Factory Line 10W40</span>
                                <span class="qty-price">Số lượng: 2 x 450.000đ</span>
                            </div>
                            <div class="fw-bold">900.000đ</div>
                        </li>
                    </ul>
                    <div class="mt-4 pt-4 border-top">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Tổng tiền hàng</span>
                            <span class="fw-bold">2.150.000đ</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span class="fw-bold">30.000đ</span>
                        </div>
                        <div class="d-flex justify-content-between mt-2 pt-2 border-top">
                            <span class="fw-bold fs-5">TỔNG CỘNG</span>
                            <span class="fw-bold fs-5 text-danger">2.180.000đ</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- 4. NEXT ACTIONS -->
            <div class="col-lg-5">
                <div class="action-buttons-group">
                    <h5 class="fw-bold mb-3 text-center text-lg-start">BƯỚC TIẾP THEO?</h5>
                    <a href="/Order/Detail/102345" class="btn btn-danger btn-lg rounded-pill fw-bold w-100 d-flex align-items-center justify-content-center">
                        <i class='bx bx-list-check me-2 fs-4'></i> XEM CHI TIẾT ĐƠN HÀNG
                    </a>
                    <a href="/Order/Tracking" class="btn-action-outline">
                        <i class='bx bx-map-pin me-2 fs-4'></i> THEO DÕI TRẠNG THÁI
                    </a>
                    <a href="/Product" class="btn-action-outline">
                        <i class='bx bx-shopping-bag me-2 fs-4'></i> TIẾP TỤC MUA HÀNG
                    </a>
                </div>

                <div class="mt-5 p-4 bg-light rounded-4">
                    <h6 class="fw-bold mb-3"><i class='bx bx-support text-danger me-2'></i> Cần hỗ trợ ngay?</h6>
                    <p class="small text-muted mb-0">Nếu bạn có bất kỳ thắc mắc nào về đơn hàng, vui lòng liên hệ Hotline: <span class="fw-bold text-dark">028 123 4567</span> hoặc chat trực tiếp với chúng tôi.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 5. SUGGESTED PRODUCTS -->
    <section class="mt-5 pt-5 border-top">
        <div class="section-title-wrapper">
            <h3 class="fw-bold text-uppercase">Có thể bạn quan tâm</h3>
        </div>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
            <div class="col">
                <div class="product-card">
                    <div class="product-img-wrapper">
                        <img src="https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=400" alt="Product" loading="lazy">
                    </div>
                    <div class="product-info flex-grow-1">
                        <span class="brand">MICHELIN</span>
                        <h6 class="name">Lốp Michelin City Grip 2 Cho Honda SH</h6>
                        <div class="product-price"><span class="current">1.850.000đ</span></div>
                    </div>
                    <button class="btn btn-add-cart w-100 rounded-pill fw-bold mt-3">THÊM VÀO GIỎ</button>
                </div>
            </div>
        </div>
    </section>
</main>
