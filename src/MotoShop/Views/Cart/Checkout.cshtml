@using MotoShop.Business.DTOs
@model CheckoutDto
@{
    ViewData["Title"] = "Thanh toán";
    var cartItems = ViewBag.CartItems as List<CartItemDto> ?? new List<CartItemDto>();
    var totalAmount = (decimal)ViewBag.TotalAmount;
}

<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/Cart">Giỏ hàng</a></li>
                <li class="breadcrumb-item active" aria-current="page">Thanh toán</li>
            </ol>
        </nav>
    </div>
</div>

<main class="container mb-5">
    <!-- 2. CHECKOUT STEPS -->
    <div class="checkout-steps">
        <div class="step-item completed">
            <div class="step-number"><i class='bx bx-check'></i></div>
            <span>Giỏ hàng</span>
        </div>
        <div class="step-line"></div>
        <div class="step-item active">
            <div class="step-number">2</div>
            <span>Thanh toán</span>
        </div>
        <div class="step-line"></div>
        <div class="step-item">
            <div class="step-number">3</div>
            <span>Hoàn tất</span>
        </div>
    </div>

    <form id="checkoutForm" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-4">
            <!-- 3. LEFT COLUMN: INFORMATION -->
            <div class="col-lg-7">
                <!-- Customer Information -->
                <div class="checkout-section">
                    <h5 class="section-subtitle"><i class='bx bx-user-circle'></i> THÔNG TIN KHÁCH HÀNG</h5>
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="FullName" class="form-label-custom">Họ và tên *</label>
                            <input asp-for="FullName" type="text" class="form-control form-control-custom" placeholder="Nhập đầy đủ họ tên" required>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label-custom">Số điện thoại *</label>
                            <input asp-for="Phone" type="tel" class="form-control form-control-custom" placeholder="Nhập số điện thoại" required>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label-custom">Email (Không bắt buộc)</label>
                            <input asp-for="Email" type="email" class="form-control form-control-custom" placeholder="Nhập địa chỉ email">
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Address" class="form-label-custom">Địa chỉ nhận hàng *</label>
                            <textarea asp-for="Address" class="form-control form-control-custom" style="height: 100px; padding-top: 15px;" placeholder="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố..." required></textarea>
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Note" class="form-label-custom">Ghi chú đơn hàng</label>
                            <textarea asp-for="Note" class="form-control form-control-custom" style="height: 80px; padding-top: 15px;" placeholder="Ví dụ: Giao sau 5h chiều, gọi trước khi giao..."></textarea>
                        </div>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="checkout-section">
                    <h5 class="section-subtitle"><i class='bx bx-credit-card-front'></i> PHƯƠNG THỨC THANH TOÁN</h5>
                    <div class="method-card active" onclick="setPayment('COD', 'cod-detail')">
                        <input type="radio" asp-for="PaymentMethod" value="COD" id="pay1" checked>
                        <div class="method-info">
                            <label for="pay1" class="name">Thanh toán khi nhận hàng (COD)</label>
                            <span class="desc">Thanh toán bằng tiền mặt khi shipper giao hàng</span>
                        </div>
                    </div>
                    <div id="cod-detail" class="payment-detail" style="display: block;">
                        Vui lòng chuẩn bị sẵn số tiền mặt tương ứng khi shipper liên hệ giao hàng.
                    </div>

                    <div class="method-card mt-3" onclick="setPayment('BankTransfer', 'bank-detail')">
                        <input type="radio" asp-for="PaymentMethod" value="BankTransfer" id="pay2">
                        <div class="method-info">
                            <label for="pay2" class="name">Chuyển khoản ngân hàng</label>
                            <span class="desc">Chuyển khoản qua ứng dụng ngân hàng hoặc cây ATM</span>
                        </div>
                    </div>
                    <div id="bank-detail" class="payment-detail">
                        <strong>Thông tin chuyển khoản:</strong><br>
                        Ngân hàng: Vietcombank - CN TP.HCM<br>
                        Số tài khoản: 0123 456 789<br>
                        Chủ TK: CTY TNHH MOTOSHOP<br>
                        Nội dung: [Họ tên] - [Số điện thoại]
                    </div>
                </div>
            </div>

            <!-- 4. RIGHT COLUMN: SUMMARY -->
            <div class="col-lg-5">
                <div class="cart-summary-card shadow-sm border-0 rounded-4 p-4">
                    <h5 class="fw-bold mb-4">TÓM TẮT ĐƠN HÀNG</h5>
                    
                    <ul class="summary-items-list list-unstyled">
                        @foreach(var item in cartItems)
                        {
                            <li class="summary-item-product d-flex gap-3 mb-3 pb-3 border-bottom">
                                <div class="summary-item-img" style="width: 60px; height: 60px;">
                                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/assets/img/elements/no-image.png" : item.ImageUrl)" class="w-100 h-100 object-fit-cover rounded" alt="@item.ProductName">
                                </div>
                                <div class="summary-item-info flex-grow-1">
                                    <div class="name fw-bold small">@item.ProductName</div>
                                    <div class="qty-price text-muted x-small">Số lượng: @item.Quantity x @item.Price.ToString("N0")đ</div>
                                </div>
                                <div class="fw-bold small">@item.Total.ToString("N0")đ</div>
                            </li>
                        }
                    </ul>

                    <div class="mt-4 pt-2">
                        <div class="summary-item d-flex justify-content-between mb-2">
                            <span class="text-muted">Tạm tính</span>
                            <span class="fw-bold">@totalAmount.ToString("N0")đ</span>
                        </div>
                        <div class="summary-item d-flex justify-content-between mb-2">
                            <span class="text-muted">Phí vận chuyển</span>
                            <span class="fw-bold text-success">Miễn phí</span>
                        </div>
                        <hr>
                        <div class="summary-total d-flex justify-content-between align-items-center mt-3">
                            <span class="fw-bold">TỔNG CỘNG</span>
                            <span class="price fs-4 fw-bolder text-danger">@totalAmount.ToString("N0")đ</span>
                        </div>
                    </div>

                    <button type="submit" id="btnPlaceOrder" class="btn btn-danger btn-lg w-100 rounded-pill fw-bold mt-4 py-3 shadow-sm">
                        XÁC NHẬN ĐẶT HÀNG
                    </button>
                    
                    <p class="text-center mt-3 small text-muted">Bằng cách nhấn Đặt hàng, bạn đồng ý với <a href="#" class="text-dark">Điều khoản dịch vụ</a> của chúng tôi.</p>
                </div>
            </div>
        </div>
    </form>
</main>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function setPayment(method, detailId) {
            document.querySelectorAll('.payment-detail').forEach(d => d.style.display = 'none');
            document.getElementById(detailId).style.display = 'block';
            document.querySelectorAll('.method-card').forEach(c => c.classList.remove('active'));
            event.currentTarget.classList.add('active');
            event.currentTarget.querySelector('input').checked = true;
        }

        document.getElementById('checkoutForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const btn = document.getElementById('btnPlaceOrder');
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Đang xử lý...';

            const formData = new FormData(this);

            try {
                const response = await fetch('/Cart/Checkout', {
                    method: 'POST',
                    body: formData
                });

                const data = await response.json();

                if (data.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Đặt hàng thành công!',
                        text: data.message,
                        showConfirmButton: false,
                        timer: 2000
                    }).then(() => {
                        window.location.href = '/Cart/Success/' + data.orderId;
                    });
                } else {
                    Swal.fire('Lỗi', data.message, 'error');
                    btn.disabled = false;
                    btn.innerHTML = 'XÁC NHẬN ĐẶT HÀNG';
                }
            } catch (error) {
                Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ.', 'error');
                btn.disabled = false;
                btn.innerHTML = 'XÁC NHẬN ĐẶT HÀNG';
            }
        });
    </script>
}
