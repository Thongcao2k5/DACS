<div class="text-end p-3 p-md-5" style="position:absolute; top:0; right:0;">
    <i class='bx bx-x fs-1 cursor-pointer text-white' onclick="UI.toggleSearch()"></i>
</div>
<div class="text-center px-3" style="width: 100%; max-width: 800px;">
    <h2 class="fw-bold mb-4 text-white">TÌM KIẾM SẢN PHẨM</h2>
    <form asp-controller="Product" asp-action="Search" method="get">
        <input type="text" name="q" class="form-control form-control-lg border-0 border-bottom rounded-0 shadow-none bg-transparent fs-2 text-center text-white" id="searchOverlayInput" placeholder="Nhập tên phụ tùng...">
    </form>
</div>
