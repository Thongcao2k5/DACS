<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MotoShop</title>
    
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- UI UTILITIES -->
    <div id="pageLoader" style="display: none !important;"><div class="loader-spinner"></div></div>
    <div id="backToTop" class="back-to-top">
        <i class='bx bx-chevron-up'></i>
    </div>

    <!-- COMMON COMPONENTS -->
    <div id="mainHeaderWrapper" class="main-header-wrapper">
        <partial name="_Header" />
    </div>
    
    <div id="searchOverlay" class="search-overlay" style="display: none;">
        <partial name="_SearchOverlay" />
    </div>
    
    <div id="mobileMenu" class="offcanvas offcanvas-start mobile-menu-offcanvas" tabindex="-1">
        <partial name="_MobileMenu" />
    </div>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white py-5 mt-5">
        <partial name="_Footer" />
    </footer>

    <!-- Scripts Order: 1. Bootstrap, 2. UI Logic, 3. Components Loader -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/header.js" asp-append-version="true"></script>
    <script src="~/js/components.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
