@using MotoShop.Business.Helpers
@model PagedList<MotoShop.Data.Models.Service>

@{
    ViewData["Title"] = "Dịch vụ sửa chữa & Bảo dưỡng";
}

<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Dịch vụ tại cửa hàng</li>
            </ol>
        </nav>
    </div>
</div>

<!-- 2. PAGE HEADER -->
<header class="container mb-5">
    <div class="p-5 bg-dark text-white rounded-4 text-center position-relative overflow-hidden">
        <div style="position: absolute; top:0; right:0; opacity: 0.1; font-size: 15rem; transform: translate(20%, -20%);">
            <i class='bx bxs-wrench'></i>
        </div>
        <h1 class="display-5 fw-bolder mb-3 position-relative">DỊCH VỤ CHĂM SÓC & BẢO DƯỠNG</h1>
        <p class="fs-5 opacity-75 position-relative">MotoShop cung cấp các giải pháp bảo dưỡng chuyên nghiệp, giúp xe vận hành êm ái, an toàn và bền bỉ hơn theo thời gian.</p>
    </div>
</header>

<main class="container mb-5">
    <!-- Search Bar -->
    <div class="row mb-4 justify-content-center">
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="input-group">
                <input type="text" name="searchTerm" class="form-control rounded-start-pill ps-4" placeholder="Tìm kiếm dịch vụ..." value="@Context.Request.Query["searchTerm"]">
                <button class="btn btn-danger rounded-end-pill px-4" type="submit">
                    <i class='bx bx-search'></i>
                </button>
            </form>
        </div>
    </div>

    <!-- 4. SERVICE LIST -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="serviceList">
        @if (Model.Any())
        {
            @foreach (var service in Model)
            {
                <div class="col">
                    <div class="service-card h-100 d-flex flex-column">
                        <div class="service-img-box">
                            <img src="@(string.IsNullOrEmpty(service.ImageUrl) ? "https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=600" : service.ImageUrl)" alt="@service.ServiceName">
                            <a asp-action="Details" asp-route-id="@service.ServiceId" class="service-quick-detail" title="Xem chi tiết">
                                <i class='bx bx-search-alt'></i>
                            </a>
                        </div>
                        <div class="service-info flex-grow-1 d-flex flex-column">
                            <h5 class="service-name">@service.ServiceName</h5>
                            <p class="service-desc">@(service.Description?.Length > 100 ? service.Description.Substring(0, 100) + "..." : service.Description)</p>
                            <div class="service-price-row mt-auto">
                                <span class="service-price-current">@service.Price.ToString("N0")đ</span>
                            </div>
                            <div class="service-actions mt-3">
                                <a asp-controller="Service" asp-action="Booking" asp-route-serviceId="@service.ServiceId" class="btn btn-danger w-100 rounded-pill fw-bold">ĐẶT LỊCH NGAY</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class='bx bx-info-circle fs-1 text-muted mb-3'></i>
                <p class="text-muted">Không tìm thấy dịch vụ nào phù hợp.</p>
                <a asp-action="Index" class="btn btn-outline-danger rounded-pill">Xem tất cả dịch vụ</a>
            </div>
        }
    </div>

    <!-- 5. PAGINATION -->
    @if (Model.TotalPages > 1)
    {
        <nav class="pagination-wrapper mt-5">
            <ul class="pagination justify-content-center">
                <li class="page-item @(!Model.HasPrevious ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-searchTerm="@Context.Request.Query["searchTerm"]">
                        <i class='bx bx-chevron-left'></i>
                    </a>
                </li>
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@Context.Request.Query["searchTerm"]">@i</a>
                    </li>
                }

                <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-searchTerm="@Context.Request.Query["searchTerm"]">
                        <i class='bx bx-chevron-right'></i>
                    </a>
                </li>
            </ul>
        </nav>
    }
</main>
