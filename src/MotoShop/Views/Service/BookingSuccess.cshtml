@{
    ViewData["Title"] = "Đặt lịch thành công";
}

<main class="container">
    <div class="success-container">
        <!-- 1. SUCCESS MESSAGE -->
        <div class="success-icon-wrapper">
            <i class='bx bx-calendar-check'></i>
        </div>
        <h1 class="fw-bold text-dark mb-2">ĐẶT LỊCH THÀNH CÔNG!</h1>
        <p class="text-muted mb-5">Cảm ơn bạn đã tin tưởng dịch vụ của <span class="text-danger fw-bold">MotoShop</span>.<br>Chúng tôi sẽ sớm liên hệ qua số điện thoại để xác nhận lịch hẹn của bạn.</p>

        <!-- 2. BOOKING INFORMATION -->
        <div class="order-info-card shadow-sm">
            <h5 class="fw-bold mb-4 border-bottom pb-3 text-uppercase"><i class='bx bx-info-circle me-2 text-danger'></i>Thông tin lịch hẹn</h5>
            <div class="booking-info-grid">
                <div class="booking-info-item">
                    <span class="booking-info-label">Mã đặt lịch</span>
                    <span class="booking-info-value">#BK-889900</span>
                </div>
                <div class="booking-info-item">
                    <span class="booking-info-label">Dịch vụ</span>
                    <span class="booking-info-value">Vệ sinh kim phun xăng Fi</span>
                </div>
                <div class="booking-info-item">
                    <span class="booking-info-label">Khách hàng</span>
                    <span class="booking-info-value">Nguyễn Văn An - 0901 234 567</span>
                </div>
                <div class="booking-info-item">
                    <span class="booking-info-label">Phương tiện</span>
                    <span class="booking-info-value">Honda AirBlade 150 (2021)</span>
                </div>
                <div class="booking-info-item" style="background: var(--primary-light); border-color: var(--primary-color);">
                    <span class="booking-info-label" style="color: var(--primary-color);">Ngày hẹn</span>
                    <span class="booking-info-value">Thứ Hai, 16/03/2026</span>
                </div>
                <div class="booking-info-item" style="background: var(--primary-light); border-color: var(--primary-color);">
                    <span class="booking-info-label" style="color: var(--primary-color);">Giờ hẹn</span>
                    <span class="booking-info-value">10:00 Sáng</span>
                </div>
            </div>
            
            <div class="mt-4 p-3 bg-light rounded-3 border-start border-warning border-4">
                <p class="small mb-0"><i class='bx bx-bulb text-warning me-1'></i> <strong>Lưu ý:</strong> Vui lòng mang xe đến cửa hàng trước giờ hẹn ít nhất 10 phút để nhân viên kỹ thuật tiếp nhận xe.</p>
            </div>
        </div>

        <!-- 3. NEXT ACTIONS -->
        <div class="row justify-content-center mt-5">
            <div class="col-md-8">
                <div class="d-flex gap-3 flex-column flex-sm-row">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-danger btn-lg rounded-pill px-4 fw-bold flex-grow-1">
                        <i class='bx bx-home-alt me-2'></i> VỀ TRANG CHỦ
                    </a>
                    <a asp-controller="Service" asp-action="Index" class="btn btn-outline-dark btn-lg rounded-pill px-4 fw-bold flex-grow-1">
                        XEM DỊCH VỤ KHÁC
                    </a>
                </div>
                <div class="mt-4">
                    <a asp-controller="Info" asp-action="Contact" class="text-muted text-decoration-none small fw-bold">
                        <i class='bx bx-phone-call me-1'></i> Liên hệ cửa hàng nếu cần dời lịch hẹn
                    </a>
                </div>
            </div>
        </div>
    </div>
</main>
