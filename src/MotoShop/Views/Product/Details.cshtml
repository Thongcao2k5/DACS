@model MotoShop.Business.DTOs.ProductDto

@{
    ViewData["Title"] = Model.ProductName;
}

<!-- 1. BREADCRUMB -->
<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/Product">@Model.CategoryName</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
            </ol>
        </nav>
    </div>
</div>

<main class="container mb-5">
    <div class="row">
        <!-- 2. PRODUCT GALLERY -->
        <div class="col-lg-6">
            <div class="product-gallery">
                <div class="main-img-wrapper" id="mainImgWrapper">
                    <img src="@(string.IsNullOrEmpty(Model.PrimaryImageUrl) ? "https://via.placeholder.com/800x800?text=No+Image" : Model.PrimaryImageUrl)" 
                         alt="@Model.ProductName" id="mainProductImg">
                </div>
                <!-- Sẽ load thêm các ảnh khác nếu có logic ở ProductDto -->
                <ul class="thumb-list mt-3">
                    <li class="thumb-item active" onclick="changeImage(this, '@Model.PrimaryImageUrl')">
                        <img src="@Model.PrimaryImageUrl" alt="Thumb">
                    </li>
                </ul>
            </div>
        </div>

        <!-- 3. PRODUCT INFO -->
        <div class="col-lg-6">
            <div class="product-detail-info">
                <a href="#" class="brand-link text-uppercase fw-bold text-danger">@Model.BrandName</a>
                <h1 class="product-name fw-bold my-3">@Model.ProductName</h1>
                
                <div class="d-flex align-items-center mb-3">
                    <div class="rating-stars me-2 text-warning">
                        <i class='bx bxs-star'></i>
                        <i class='bx bxs-star'></i>
                        <i class='bx bxs-star'></i>
                        <i class='bx bxs-star'></i>
                        <i class='bx bxs-star-half'></i>
                    </div>
                    <span class="text-muted small">(24 đánh giá) | SKU: @Model.ProductId.ToString("D5")</span>
                </div>

                <div class="detail-price text-danger display-5 fw-bold mb-4">@Model.MinPrice.ToString("N0")đ</div>

                <p class="text-muted mb-4 fs-5">@Model.Description</p>

                <!-- Quantity & Actions -->
                <div class="variant-group mb-4">
                    <div class="variant-title fw-bold mb-2">Số lượng:</div>
                    <div class="qty-selector d-flex">
                        <button class="btn btn-outline-secondary px-3" onclick="updateQty(-1)"><i class='bx bx-minus'></i></button>
                        <input type="text" class="form-control text-center mx-2" style="width: 60px;" value="1" id="qtyInput" readonly>
                        <button class="btn btn-outline-secondary px-3" onclick="updateQty(1)"><i class='bx bx-plus'></i></button>
                    </div>
                </div>

                <div class="btn-buy-group d-flex gap-3">
                    <button type="button" onclick="handleAddToCart(false)" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold flex-grow-1">
                        <i class='bx bx-cart-add fs-4 me-2'></i> THÊM VÀO GIỎ
                    </button>
                    <button type="button" onclick="handleAddToCart(true)" class="btn btn-dark btn-lg rounded-pill px-5 fw-bold flex-grow-1">MUA NGAY</button>
                </div>

                <div class="mt-4 pt-4 border-top">
                    <div class="d-flex align-items-center mb-2">
                        <i class='bx bx-check-shield text-success fs-4 me-2'></i>
                        <span class="small fw-bold">Bảo hành chính hãng 12 tháng</span>
                    </div>
                    <div class="d-flex align-items-center mb-2">
                        <i class='bx bx-refresh text-success fs-4 me-2'></i>
                        <span class="small fw-bold">Đổi trả trong 7 ngày nếu lỗi sản xuất</span>
                    </div>
                    <div class="d-flex align-items-center">
                        <i class='bx bx-package text-success fs-4 me-2'></i>
                        <span class="small fw-bold">Còn hàng - Giao ngay toàn quốc</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Gallery logic
        function changeImage(thumb, src) {
            document.getElementById('mainProductImg').src = src;
            document.querySelectorAll('.thumb-item').forEach(i => i.classList.remove('active'));
            thumb.classList.add('active');
        }

        // Qty logic
        function updateQty(val) {
            const input = document.getElementById('qtyInput');
            let current = parseInt(input.value);
            current += val;
            if (current < 1) current = 1;
            input.value = current;
        }

        async function handleAddToCart(isBuyNow) {
            const variantId = @Model.DefaultVariantId;
            const quantity = parseInt(document.getElementById('qtyInput').value);

            if (!variantId || variantId === 0) {
                Swal.fire('Chú ý', 'Sản phẩm này hiện chưa có biến thể để đặt hàng.', 'warning');
                return;
            }

            try {
                const response = await fetch('/Cart/AddToCart', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `variantId=${variantId}&quantity=${quantity}`
                });
                
                const data = await response.json();
                
                if (data.success) {
                    if (isBuyNow) {
                        window.location.href = '/Cart/Checkout';
                    } else {
                        Swal.fire({
                            icon: 'success',
                            title: 'Tuyệt vời!',
                            text: data.message,
                            showConfirmButton: false,
                            timer: 1500,
                            toast: true,
                            position: 'top-end'
                        });
                        if (typeof updateCartBadge === "function") updateCartBadge();
                        if (typeof showCartSuccessToast === "function") showCartSuccessToast(data.message);
                    }
                } else {
                    Swal.fire('Thông báo', data.message, 'info');
                }
            } catch (error) {
                Swal.fire('Lỗi', 'Không thể kết nối đến máy chủ.', 'error');
            }
        }
    </script>
}
