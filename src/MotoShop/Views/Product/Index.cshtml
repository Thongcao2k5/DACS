@using MotoShop.Business.Helpers
@model PagedList<MotoShop.Business.DTOs.ProductDto>

@{
    ViewData["Title"] = "Tất cả sản phẩm";
}

<!-- 1. BREADCRUMB -->
<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Tất cả sản phẩm</li>
            </ol>
        </nav>
    </div>
</div>

<main class="container mb-5">
    <div class="row">
        <!-- 2. FILTER SIDEBAR (Desktop) -->
        <aside class="col-lg-3 d-none d-lg-block">
            <div class="filter-sidebar">
                <!-- Category Filter -->
                <div class="filter-widget">
                    <h5 class="filter-title">Danh mục</h5>
                    <ul class="filter-list">
                        <!-- Sẽ load dynamic sau -->
                        <li class="filter-item">
                            <div class="d-flex align-items-center">
                                <input type="checkbox" id="cat1">
                                <label for="cat1">Phụ tùng máy</label>
                            </div>
                        </li>
                        <li class="filter-item">
                            <div class="d-flex align-items-center">
                                <input type="checkbox" id="cat2">
                                <label for="cat2">Dàn chân</label>
                            </div>
                        </li>
                    </ul>
                </div>

                <!-- Brand Filter -->
                <div class="filter-widget">
                    <h5 class="filter-title">Thương hiệu</h5>
                    <ul class="filter-list">
                        <li class="filter-item">
                            <div class="d-flex align-items-center">
                                <input type="checkbox" id="brand1">
                                <label for="brand1">Honda</label>
                            </div>
                        </li>
                    </ul>
                </div>

                <!-- Price Filter -->
                <div class="filter-widget">
                    <h5 class="filter-title">Khoảng giá (đ)</h5>
                    <div class="price-range-inputs">
                        <input type="number" placeholder="Từ">
                        <span>-</span>
                        <input type="number" placeholder="Đến">
                    </div>
                    <button class="btn btn-danger btn-sm w-100 mt-3 rounded-pill">ÁP DỤNG</button>
                </div>
            </div>
        </aside>

        <!-- 3. MAIN CONTENT -->
        <div class="col-lg-9">
            <!-- Mobile Filter Button -->
            <button class="btn btn-outline-dark mobile-filter-btn d-lg-none" data-bs-toggle="offcanvas" data-bs-target="#mobileFilter">
                <i class='bx bx-filter-alt'></i> BỘ LỌC
            </button>

            <!-- Page Title & Sort Bar -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h3 class="fw-bold mb-0">Tất cả sản phẩm</h3>
                <p class="text-muted mb-0 d-none d-md-block">Tìm thấy @Model.TotalCount sản phẩm</p>
            </div>

            <div class="shop-control-bar">
                <div class="d-flex align-items-center">
                    <span class="text-muted me-3 small">Sắp xếp:</span>
                    <select class="sort-select">
                        <option>Mặc định</option>
                        <option>Giá tăng dần</option>
                        <option>Giá giảm dần</option>
                        <option>Sản phẩm mới</option>
                        <option>Bán chạy nhất</option>
                    </select>
                </div>
                <div class="d-flex align-items-center">
                    <span class="text-muted me-3 small d-none d-md-block">Chế độ xem:</span>
                    <button class="view-mode-btn active" title="Grid View"><i class='bx bxs-grid-alt'></i></button>
                    <button class="view-mode-btn" title="List View"><i class='bx bx-list-ul'></i></button>
                </div>
            </div>

            <!-- Product Grid -->
            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4" id="productGrid">
                @foreach (var product in Model)
                {
                    <div class="col">
                        <div class="product-card h-100 d-flex flex-column">
                            <div class="product-img-wrapper">
                                <a asp-action="Details" asp-route-slug="@product.Slug">
                                    <img src="@(string.IsNullOrEmpty(product.PrimaryImageUrl) ? "https://via.placeholder.com/400x400?text=No+Image" : product.PrimaryImageUrl)" 
                                         alt="@product.ProductName" loading="lazy">
                                </a>
                            </div>
                            <div class="product-info flex-grow-1">
                                <span class="brand text-uppercase">@product.BrandName</span>
                                <h6 class="name">
                                    <a asp-action="Details" asp-route-slug="@product.Slug" class="text-decoration-none text-dark">
                                        @product.ProductName
                                    </a>
                                </h6>
                                <div class="product-price">
                                    <span class="current text-danger fw-bold">@product.MinPrice.ToString("N0")đ</span>
                                </div>
                            </div>
                            <button class="btn btn-add-cart rounded-pill fw-bold mt-3">
                                <i class='bx bx-cart-add fs-4'></i> <span class="d-none d-md-inline ms-2">THÊM VÀO GIỎ</span>
                            </button>
                        </div>
                    </div>
                }
            </div>

            <!-- 4. PAGINATION -->
            @if (Model.TotalPages > 1)
            {
                <nav class="pagination-wrapper mt-5">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(!Model.HasPrevious ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)"><i class='bx bx-chevron-left'></i></a>
                        </li>
                        
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                            </li>
                        }

                        <li class="page-item @(!Model.HasNext ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)"><i class='bx bx-chevron-right'></i></a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</main>
