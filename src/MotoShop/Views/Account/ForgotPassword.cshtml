@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">Quên mật khẩu</li>
            </ol>
        </nav>
    </div>
</div>

<main class="auth-wrapper">
    <div class="container">
        <!-- 2. FORGOT PASSWORD CONTAINER -->
        <div class="auth-card" style="max-width: 480px;">
            <div class="auth-header">
                <div class="mb-3 text-danger fs-1">
                    <i class='bx bx-lock-open-alt'></i>
                </div>
                <h2>QUÊN MẬT KHẨU?</h2>
                <p>Nhập email hoặc số điện thoại của bạn để nhận hướng dẫn đặt lại mật khẩu.</p>
            </div>

            <!-- 3. RESET PASSWORD FORM -->
            <form id="forgotPasswordForm" onsubmit="handleResetRequest(event)">
                <div class="mb-4">
                    <label class="form-label-custom">Email hoặc Số điện thoại *</label>
                    <input type="text" id="resetInput" class="form-control form-control-custom" placeholder="example@email.com hoặc 0901234567" required>
                    <div id="formatError" class="text-danger small mt-1 d-none">Vui lòng nhập đúng định dạng email hoặc số điện thoại.</div>
                </div>

                <div id="resetSuccess" class="alert alert-success d-none py-3 mb-4">
                    <div class="d-flex">
                        <i class='bx bx-check-circle fs-4 me-2'></i>
                        <div>
                            <p class="fw-bold mb-1">Yêu cầu đã được gửi!</p>
                            <p class="small mb-0">Nếu tài khoản tồn tại, chúng tôi đã gửi hướng dẫn đặt lại mật khẩu. Vui lòng kiểm tra hộp thư của bạn.</p>
                        </div>
                    </div>
                </div>

                <button type="submit" id="btnSubmit" class="btn btn-danger btn-lg w-100 rounded-pill fw-bold mb-3">GỬI YÊU CẦU</button>
                
                <p class="text-center small text-muted px-3">
                    <i class='bx bx-info-circle me-1'></i> 
                    Vì lý do bảo mật, chúng tôi sẽ không thông báo tài khoản có tồn tại trong hệ thống hay không.
                </p>
            </form>

            <!-- 4. ADDITIONAL LINKS -->
            <div class="mt-5 pt-4 border-top text-center">
                <p class="mb-2 small">Nhớ mật khẩu? <a href="/Account/Login" class="text-danger fw-bold text-decoration-none">Đăng nhập</a></p>
                <p class="mb-0 small">Chưa có tài khoản? <a href="/Account/Register" class="text-danger fw-bold text-decoration-none">Đăng ký ngay</a></p>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function handleResetRequest(e) {
            e.preventDefault();
            const input = document.getElementById('resetInput').value;
            const successMsg = document.getElementById('resetSuccess');
            const btn = document.getElementById('btnSubmit');
            const formatError = document.getElementById('formatError');

            // Regex đơn giản để check email/phone
            const isEmail = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(input);
            const isPhone = /^[0-9]{10,11}$/.test(input);

            if (!isEmail && !isPhone) {
                formatError.classList.remove('d-none');
                return;
            }

            formatError.classList.add('d-none');
            
            // Giả lập gửi thành công
            btn.disabled = true;
            btn.innerText = 'ĐANG GỬI...';
            
            setTimeout(() => {
                successMsg.classList.remove('d-none');
                btn.innerText = 'GỬI LẠI YÊU CẦU';
                btn.disabled = false;
                btn.classList.replace('btn-danger', 'btn-outline-dark');
            }, 1500);
        }
    </script>
}
