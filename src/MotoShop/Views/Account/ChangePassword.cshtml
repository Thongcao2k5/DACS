@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="breadcrumb-wrapper">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/Account/Profile">Tài khoản</a></li>
                <li class="breadcrumb-item active" aria-current="page">Đổi mật khẩu</li>
            </ol>
        </nav>
    </div>
</div>

<main class="container mb-5">
    <div class="row g-4">
        <!-- 2. SIDEBAR MENU (Left) -->
        <aside class="col-lg-3">
            <div class="account-sidebar">
                <div class="d-flex align-items-center gap-3 mb-4 pb-4 border-bottom">
                    <div style="width: 50px; height: 50px;">
                        <img src="https://i.pravatar.cc/150?u=1" class="rounded-circle w-100 h-100 object-fit-cover" alt="User">
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Nguyễn Văn An</h6>
                        <p class="text-muted small mb-0">Thành viên Bạc</p>
                    </div>
                </div>
                <ul class="account-nav">
                    <li class="account-nav-item"><a href="/Account/Profile" class="account-nav-link"><i class='bx bx-user'></i> Thông tin cá nhân</a></li>
                    <li class="account-nav-item"><a href="/Order" class="account-nav-link"><i class='bx bx-package'></i> Đơn hàng của tôi</a></li>
                    <li class="account-nav-item"><a href="/Account/AddressBook" class="account-nav-link"><i class='bx bx-map'></i> Địa chỉ giao hàng</a></li>
                    <li class="account-nav-item"><a href="/Product/Wishlist" class="account-nav-link"><i class='bx bx-heart'></i> Sản phẩm yêu thích</a></li>
                    <li class="account-nav-item"><a href="/Account/ChangePassword" class="account-nav-link active"><i class='bx bx-lock-alt'></i> Đổi mật khẩu</a></li>
                    <li class="account-nav-item mt-3 pt-3 border-top">
                        <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="d-none"></form>
                        <a href="javascript:void(0)" class="account-nav-link text-danger" onclick="confirmLogout()"><i class='bx bx-log-out'></i> Đăng xuất</a>
                    </li>
                </ul>
            </div>
        </aside>

        <!-- 3. MAIN CONTENT (Right) -->
        <div class="col-lg-9">
            <div style="max-width: 550px;">
                <div class="profile-section-card">
                    <h4 class="fw-bold mb-2">ĐỔI MẬT KHẨU</h4>
                    <p class="text-muted small mb-4">Để bảo mật tài khoản, vui lòng không chia sẻ mật khẩu cho người khác.</p>

                    <form id="changePasswordForm" onsubmit="handleChangePass(event)">
                        <!-- Current Password -->
                        <div class="mb-3">
                            <label class="form-label-custom">Mật khẩu hiện tại *</label>
                            <div class="password-group">
                                <input type="password" id="currPass" class="form-control form-control-custom" placeholder="Nhập mật khẩu đang dùng" required>
                                <i class='bx bx-hide password-toggle-icon' onclick="togglePass('currPass', this)"></i>
                            </div>
                        </div>

                        <!-- New Password -->
                        <div class="mb-3">
                            <label class="form-label-custom">Mật khẩu mới *</label>
                            <div class="password-group">
                                <input type="password" id="newPass" class="form-control form-control-custom" placeholder="Nhập mật khẩu mới" onkeyup="checkRequirements()" required>
                                <i class='bx bx-hide password-toggle-icon' onclick="togglePass('newPass', this)"></i>
                            </div>
                            <!-- Requirements -->
                            <ul class="password-requirements">
                                <li id="reqLength"><i class='bx bx-circle'></i> Ít nhất 8 ký tự</li>
                                <li id="reqUpper"><i class='bx bx-circle'></i> Có chữ cái in hoa</li>
                                <li id="reqNumber"><i class='bx bx-circle'></i> Có ít nhất 1 chữ số</li>
                            </ul>
                        </div>

                        <!-- Confirm New Password -->
                        <div class="mb-4">
                            <label class="form-label-custom">Xác nhận mật khẩu mới *</label>
                            <div class="password-group">
                                <input type="password" id="confirmPass" class="form-control form-control-custom" placeholder="Nhập lại mật khẩu mới" required>
                                <i class='bx bx-hide password-toggle-icon' onclick="togglePass('confirmPass', this)"></i>
                            </div>
                        </div>

                        <div id="passSuccess" class="alert alert-success d-none py-2 small mb-3">
                            <i class='bx bx-check-circle me-1'></i> Đổi mật khẩu thành công.
                        </div>
                        <div id="passError" class="alert alert-danger d-none py-2 small mb-3">
                            <i class='bx bx-error-circle me-1'></i> Mật khẩu hiện tại không chính xác.
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn btn-danger rounded-pill px-5 fw-bold">LƯU THAY ĐỔI</button>
                            <button type="reset" class="btn btn-outline-dark rounded-pill px-4 fw-bold">HỦY</button>
                        </div>
                    </form>
                </div>

                <!-- 4. SECURITY TIPS -->
                <div class="security-tips-box">
                    <h6><i class='bx bxs-shield-alt me-2'></i> MẸO BẢO MẬT MẬT KHẨU</h6>
                    <ul>
                        <li>Sử dụng mật khẩu mà bạn chưa từng dùng ở bất kỳ nơi nào khác.</li>
                        <li>Kết hợp chữ cái, số và ký hiệu đặc biệt để tăng độ mạnh.</li>
                        <li>Thay đổi mật khẩu ít nhất 6 tháng một lần để đảm bảo an toàn.</li>
                        <li>Luôn đăng xuất khỏi tài khoản nếu sử dụng thiết bị công cộng.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        function togglePass(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bx-hide', 'bx-show');
            } else {
                input.type = 'password';
                icon.classList.replace('bx-show', 'bx-hide');
            }
        }

        function checkRequirements() {
            const val = document.getElementById('newPass').value;
            
            // Check length
            const reqLength = document.getElementById('reqLength');
            if (val.length >= 8) reqLength.classList.add('valid');
            else reqLength.classList.remove('valid');

            // Check upper
            const reqUpper = document.getElementById('reqUpper');
            if (/[A-Z]/.test(val)) reqUpper.classList.add('valid');
            else reqUpper.classList.remove('valid');

            // Check number
            const reqNumber = document.getElementById('reqNumber');
            if (/[0-9]/.test(val)) reqNumber.classList.add('valid');
            else reqNumber.classList.remove('valid');
        }

        function handleChangePass(e) {
            e.preventDefault();
            const curr = document.getElementById('currPass').value;
            const errorMsg = document.getElementById('passError');
            
            // Giả lập check sai mk cũ
            if (curr !== '123456') {
                errorMsg.classList.remove('d-none');
                document.getElementById('passSuccess').classList.add('d-none');
            } else {
                errorMsg.classList.add('d-none');
                document.getElementById('passSuccess').classList.remove('d-none');
            }
        }

        function confirmLogout() {
            if(confirm('Bạn có chắc chắn muốn đăng xuất?')) {
                document.getElementById('logoutForm').submit();
            }
        }
    </script>
}
