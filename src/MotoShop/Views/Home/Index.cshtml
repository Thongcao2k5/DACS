@model MotoShop.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ";
}

<!-- 1. HERO BANNER / SLIDER -->
<section class="hero-section p-0">
    <div id="heroSlider" class="carousel slide carousel-fade" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroSlider" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#heroSlider" data-bs-slide-to="1"></button>
        </div>
        <div class="carousel-inner">
            <div class="carousel-item active" data-bs-interval="5000">
                <img src="https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=1600&q=80" class="d-block w-100" style="height: 600px; object-fit: cover;" alt="Banner 1">
                <div class="carousel-caption d-flex align-items-center h-100 text-start" style="left: 10%; right: 10%; bottom: 0;">
                    <div class="col-lg-6">
                        <span class="badge bg-danger mb-3 px-3 py-2 animate__animated animate__fadeInDown">NEW ARRIVAL 2026</span>
                        <h1 class="display-3 fw-bolder text-white mb-3 animate__animated animate__fadeInLeft">PHỤ TÙNG XE MÁY<br><span class="text-danger">CHÍNH HÃNG</span></h1>
                        <p class="fs-5 mb-4 text-white-50 animate__animated animate__fadeInLeft animate__delay-1s">Chất lượng vượt trội cho xế yêu của bạn. Nhập khẩu trực tiếp từ Nhật Bản, Ý và Thái Lan.</p>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-danger btn-lg rounded-pill px-5 fw-bold animate__animated animate__fadeInUp animate__delay-1s">MUA NGAY</a>
                    </div>
                </div>
            </div>
            <div class="carousel-item" data-bs-interval="5000">
                <img src="https://images.unsplash.com/photo-1449426468159-d96dbf08f19f?w=1600&q=80" class="d-block w-100" style="height: 600px; object-fit: cover;" alt="Banner 2">
                <div class="carousel-caption d-flex align-items-center h-100 text-start" style="left: 10%; right: 10%; bottom: 0;">
                    <div class="col-lg-6">
                        <span class="badge bg-warning mb-3 px-3 py-2">SIÊU ƯU ĐÃI</span>
                        <h1 class="display-3 fw-bolder text-white mb-3">BẢO DƯỠNG TRỌN GÓI<br><span class="text-warning">TIẾT KIỆM 30%</span></h1>
                        <p class="fs-5 mb-4 text-white-50">Combo phụ tùng nồi - lọc gió - bugi cho mọi dòng xe tay ga. Duy nhất trong tháng này.</p>
                        <a asp-controller="Product" asp-action="Index" class="btn btn-warning btn-lg rounded-pill px-5 fw-bold">XEM SẢN PHẨM</a>
                    </div>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroSlider" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroSlider" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
</section>

<!-- 2. CATEGORY QUICK ACCESS -->
<section class="bg-white">
    <div class="container">
        <div class="section-title-wrapper text-center">
            <h2 class="section-title center text-uppercase">Danh mục nổi bật</h2>
        </div>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-6 g-3">
            <div class="col">
                <a asp-controller="Product" asp-action="Category" asp-route-id="1" class="cat-quick-card">
                    <div class="cat-img-circle"><i class='bx bxs-component fs-1 text-danger'></i></div>
                    <span>Phụ tùng máy</span>
                </a>
            </div>
            <div class="col">
                <a asp-controller="Product" asp-action="Category" asp-route-id="4" class="cat-quick-card">
                    <div class="cat-img-circle"><i class='bx bxs-wrench fs-1 text-danger'></i></div>
                    <span>Dàn chân</span>
                </a>
            </div>
            <div class="col">
                <a asp-controller="Product" asp-action="Category" asp-route-id="7" class="cat-quick-card">
                    <div class="cat-img-circle"><i class='bx bxs-droplet fs-1 text-danger'></i></div>
                    <span>Nhớt máy</span>
                </a>
            </div>
            <div class="col">
                <a asp-controller="Product" asp-action="Category" asp-route-id="10" class="cat-quick-card">
                    <div class="cat-img-circle"><i class='bx bxs-bolt fs-1 text-danger'></i></div>
                    <span>Đồ chơi xe</span>
                </a>
            </div>
            <div class="col">
                <a asp-controller="Product" asp-action="Category" asp-route-id="5" class="cat-quick-card">
                    <div class="cat-img-circle"><i class='bx bxs-shield fs-1 text-danger'></i></div>
                    <span>Vỏ lốp xe</span>
                </a>
            </div>
            <div class="col">
                <a asp-controller="Product" asp-action="Index" class="cat-quick-card">
                    <div class="cat-img-circle"><i class='bx bxs-grid fs-1 text-danger'></i></div>
                    <span>Tất cả</span>
                </a>
            </div>
        </div>
    </div>
</section>

<!-- 3. HOT PROMOTIONS -->
<section class="promo-section">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6">
                <div class="promo-banner" style="background-image: linear-gradient(rgba(230,0,35,0.7), rgba(230,0,35,0.7)), url('https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=800');">
                    <div class="promo-content">
                        <h2>ƯU ĐÃI THÁNG 3</h2>
                        <p>Giảm ngay 200k cho đơn hàng bảo dưỡng trọn gói.</p>
                        <a asp-controller="Product" asp-action="Promotion" class="btn-promo-action text-decoration-none">NHẬN ƯU ĐÃI</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="promo-banner" style="background-image: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1449426468159-d96dbf08f19f?w=800');">
                    <div class="promo-content text-white">
                        <h2>MIỄN PHÍ VẬN CHUYỂN</h2>
                        <p>Áp dụng cho mọi đơn hàng phụ tùng trên 500k.</p>
                        <a asp-controller="Info" asp-action="ShippingPolicy" class="btn-promo-action text-decoration-none">XEM CHI TIẾT</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 4. FEATURED PRODUCTS -->
<section class="bg-white">
    <div class="container">
        <div class="section-title-wrapper d-flex justify-content-between align-items-end">
            <div>
                <h2 class="section-title text-uppercase">Sản phẩm nổi bật</h2>
            </div>
            <a asp-controller="Product" asp-action="Index" class="text-danger fw-bold text-decoration-none">Xem thêm <i class='bx bx-right-arrow-alt'></i></a>
        </div>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4" id="featuredProducts">
            @if (Model.FeaturedProducts != null && Model.FeaturedProducts.Any())
            {
                foreach (var product in Model.FeaturedProducts)
                {
                    <div class="col">
                        <div class="product-card">
                            <span class="product-badge badge-featured">Featured</span>
                            <div class="product-img-wrapper">
                                <a asp-controller="Product" asp-action="Details" asp-route-slug="@product.Slug">
                                    <img src="@(string.IsNullOrEmpty(product.PrimaryImageUrl) ? "https://via.placeholder.com/400x400?text=No+Image" : product.PrimaryImageUrl)" 
                                         alt="@product.ProductName" loading="lazy">
                                </a>
                            </div>
                            <div class="product-info flex-grow-1">
                                <span class="brand">@product.BrandName</span>
                                <h6 class="name">
                                    <a asp-controller="Product" asp-action="Details" asp-route-slug="@product.Slug" class="text-decoration-none text-dark">
                                        @product.ProductName
                                    </a>
                                </h6>
                                <div class="product-price">
                                    <span class="current">@product.MinPrice.ToString("N0")đ</span>
                                </div>
                            </div>
                            <button class="btn btn-add-cart rounded-pill fw-bold mt-3">
                                <i class='bx bx-cart-add fs-4'></i> <span class="d-none d-md-inline ms-2">THÊM VÀO GIỎ</span>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- 5. BEST SELLING PRODUCTS -->
<section class="bg-light">
    <div class="container">
        <div class="section-title-wrapper d-flex justify-content-between align-items-end">
            <div>
                <h2 class="section-title text-uppercase">Sản phẩm bán chạy</h2>
            </div>
            <a asp-controller="Product" asp-action="Index" class="text-danger fw-bold text-decoration-none">Xem thêm <i class='bx bx-right-arrow-alt'></i></a>
        </div>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4" id="bestSellingProducts">
            @if (Model.BestSellingProducts != null && Model.BestSellingProducts.Any())
            {
                foreach (var product in Model.BestSellingProducts)
                {
                    <div class="col">
                        <div class="product-card">
                            <span class="product-badge badge-hot">Best Seller</span>
                            <div class="product-img-wrapper">
                                <a asp-controller="Product" asp-action="Details" asp-route-slug="@product.Slug">
                                    <img src="@(string.IsNullOrEmpty(product.PrimaryImageUrl) ? "https://via.placeholder.com/400x400?text=No+Image" : product.PrimaryImageUrl)" 
                                         alt="@product.ProductName" loading="lazy">
                                </a>
                            </div>
                            <div class="product-info flex-grow-1">
                                <span class="brand">@product.BrandName</span>
                                <h6 class="name">@product.ProductName</h6>
                                <div class="product-price">
                                    <span class="current">@product.MinPrice.ToString("N0")đ</span>
                                </div>
                            </div>
                            <button class="btn btn-add-cart rounded-pill fw-bold mt-3">
                                <i class='bx bx-cart-add fs-4'></i> <span class="d-none d-md-inline ms-2">THÊM VÀO GIỎ</span>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- 6. BRAND SHOWCASE -->
<section class="bg-white">
    <div class="container">
        <div class="section-title-wrapper text-center">
            <h5 class="text-muted text-uppercase mb-4">Thương hiệu đồng hành</h5>
        </div>
        <div class="row align-items-center justify-content-center g-4">
            <div class="col-4 col-md-2 brand-item"><img src="https://upload.wikimedia.org/wikipedia/commons/7/7b/Honda_Logo.svg" alt="Honda"></div>
            <div class="col-4 col-md-2 brand-item"><img src="https://upload.wikimedia.org/wikipedia/commons/e/e0/Yamaha_logo.svg" alt="Yamaha"></div>
            <div class="col-4 col-md-2 brand-item"><img src="https://www.motul.com/dist/motul-logo.svg" alt="Motul"></div>
            <div class="col-4 col-md-2 brand-item"><img src="https://ohlins.asia/wp-content/themes/ohlins/assets/img/logo-ohlins.svg" alt="Ohlins"></div>
            <div class="col-4 col-md-2 brand-item"><img src="https://upload.wikimedia.org/wikipedia/fr/4/4e/Michelin_logo.svg" alt="Michelin"></div>
        </div>
    </div>
</section>

<!-- 7. NEW PRODUCTS -->
<section class="bg-light">
    <div class="container">
        <div class="section-title-wrapper d-flex justify-content-between align-items-end">
            <div>
                <h2 class="section-title text-uppercase">Sản phẩm mới</h2>
            </div>
            <a asp-controller="Product" asp-action="Index" class="text-danger fw-bold text-decoration-none">Xem thêm <i class='bx bx-right-arrow-alt'></i></a>
        </div>
        <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4" id="newProducts">
            @if (Model.NewProducts != null && Model.NewProducts.Any())
            {
                foreach (var product in Model.NewProducts)
                {
                    <div class="col">
                        <div class="product-card">
                            <span class="product-badge badge-new">New</span>
                            <div class="product-img-wrapper">
                                <a asp-controller="Product" asp-action="Details" asp-route-slug="@product.Slug">
                                    <img src="@(string.IsNullOrEmpty(product.PrimaryImageUrl) ? "https://via.placeholder.com/400x400?text=No+Image" : product.PrimaryImageUrl)" 
                                         alt="@product.ProductName" loading="lazy">
                                </a>
                            </div>
                            <div class="product-info flex-grow-1">
                                <span class="brand">@product.BrandName</span>
                                <h6 class="name">@product.ProductName</h6>
                                <div class="product-price">
                                    <span class="current">@product.MinPrice.ToString("N0")đ</span>
                                </div>
                            </div>
                            <button class="btn btn-add-cart rounded-pill fw-bold mt-3">
                                <i class='bx bx-cart-add fs-4'></i> <span class="d-none d-md-inline ms-2">THÊM VÀO GIỎ</span>
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- 8. ADVANTAGES / WHY CHOOSE US -->
<section class="bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="advantage-box">
                    <div class="advantage-icon"><i class='bx bx-timer'></i></div>
                    <div class="advantage-info">
                        <h6>GIAO HÀNG NHANH</h6>
                        <p>Nội thành TP.HCM trong 2h</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="advantage-box">
                    <div class="advantage-icon"><i class='bx bxs-check-shield'></i></div>
                    <div class="advantage-info">
                        <h6>HÀNG CHÍNH HÃNG</h6>
                        <p>Cam kết chất lượng 100%</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="advantage-box">
                    <div class="advantage-icon"><i class='bx bx-badge-check'></i></div>
                    <div class="advantage-info">
                        <h6>GIÁ TỐT NHẤT</h6>
                        <p>Luôn có ưu đãi hấp dẫn</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <div class="advantage-box">
                    <div class="advantage-icon"><i class='bx bx-headphone'></i></div>
                    <div class="advantage-info">
                        <h6>HỖ TRỢ 24/7</h6>
                        <p>Tư vấn kỹ thuật chuyên sâu</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 9. BLOG / NEWS -->
<section class="bg-light">
    <div class="container">
        <div class="section-title-wrapper text-center">
            <h2 class="section-title center text-uppercase">Tin tức & Kinh nghiệm</h2>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <img src="https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=600" class="card-img-top" alt="Blog">
                    <div class="card-body p-4">
                        <span class="text-danger small fw-bold">25 Tháng 12, 2025</span>
                        <h5 class="fw-bold mt-2">Hướng dẫn bảo dưỡng nồi xe tay ga đúng cách</h5>
                        <p class="text-muted small">Bảo dưỡng nồi định kỳ giúp xe vận hành êm ái và tiết kiệm xăng hơn...</p>
                        <a asp-controller="Blog" asp-action="Detail" asp-route-slug="bao-duong-noi" class="text-danger fw-bold text-decoration-none small">ĐỌC TIẾP <i class='bx bx-right-arrow-alt'></i></a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <img src="https://images.unsplash.com/photo-1449426468159-d96dbf08f19f?w=600" class="card-img-top" alt="Blog">
                    <div class="card-body p-4">
                        <span class="text-danger small fw-bold">20 Tháng 12, 2025</span>
                        <h5 class="fw-bold mt-2">Cách phân biệt nhớt Motul thật và giả</h5>
                        <p class="text-muted small">Tránh mua phải hàng kém chất lượng làm hư hại động cơ xe của bạn...</p>
                        <a asp-controller="Blog" asp-action="Detail" asp-route-slug="phan-biet-nhot" class="text-danger fw-bold text-decoration-none small">ĐỌC TIẾP <i class='bx bx-right-arrow-alt'></i></a>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <img src="https://images.unsplash.com/photo-1558981403-c5f9899a28bc?w=600" class="card-img-top" alt="Blog">
                    <div class="card-body p-4">
                        <span class="text-danger small fw-bold">15 Tháng 12, 2025</span>
                        <h5 class="fw-bold mt-2">Top 5 loại lốp xe bền nhất cho Honda SH</h5>
                        <p class="text-muted small">Lựa chọn lốp xe phù hợp giúp tăng độ bám đường và an toàn khi di chuyển...</p>
                        <a asp-controller="Blog" asp-action="Detail" asp-route-slug="top-5-lop-xe" class="text-danger fw-bold text-decoration-none small">ĐỌC TIẾP <i class='bx bx-right-arrow-alt'></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 10. NEWSLETTER SUBSCRIPTION -->
<section class="newsletter-section text-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <h2 class="fw-bold mb-3">NHẬN THÔNG TIN KHUYẾN MÃI</h2>
                <p class="mb-5 opacity-75">Đăng ký email để nhận ngay các thông tin về sản phẩm mới và các chương trình ưu đãi đặc biệt sớm nhất từ MOTO SHOP.</p>
                <form class="news-input-group d-flex">
                    <input type="email" class="form-control" placeholder="Nhập địa chỉ email của bạn..." required>
                    <button type="submit" class="btn btn-subscribe">ĐĂNG KÝ</button>
                </form>
            </div>
        </div>
    </div>
</section>
